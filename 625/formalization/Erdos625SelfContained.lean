    rw [← G.sum_degrees_eq_twice_card_edges]
    calc
      ∑ w : V, G.degree w ≤ ∑ _w : V, G.maxDegree := by
        exact Finset.sum_le_sum fun _ _ ↦ G.degree_le_maxDegree _
