section Erdos625SelfContained_Module_Erdos625_BlockBoundedDifferences

/-!
# Bounded differences for finite uniformly distributed blocks

This module proves the finite-product bounded-differences inequality for a
dependent family of nonempty finite block spaces.  The proof is an explicit
induction over the blocks.  At each step, mathlib's Hoeffding lemma is applied
to the uniformly distributed head-block conditional means.
-/

open MeasureTheory Set
open scoped BigOperators ENNReal NNReal ProbabilityTheory
open ProbabilityTheory

namespace Erdos625

universe u

/-! ## Uniform finite means -/

/-- The normalized sum of a real-valued function on a nonempty finite type. -/
noncomputable def finiteMean {A : Type u} [Fintype A] (f : A тЖТ тДЭ) : тДЭ :=
  (тИС a, f a) / Fintype.card A

theorem finiteMean_congr {A : Type u} [Fintype A] {f g : A тЖТ тДЭ}
    (h : тИА a, f a = g a) : finiteMean f = finiteMean g := by
  unfold finiteMean
  congr 1
  exact Finset.sum_congr rfl fun a _ тЖж h a

@[simp]
theorem finiteMean_const {A : Type u} [Fintype A] [Nonempty A] (r : тДЭ) :
    finiteMean (fun _ : A тЖж r) = r := by
  unfold finiteMean
  rw [Finset.sum_const, Finset.card_univ, nsmul_eq_mul]
  have hcard : (Fintype.card A : тДЭ) тЙа 0 := by
    exact_mod_cast Fintype.card_ne_zero
  field_simp

theorem finiteMean_add {A : Type u} [Fintype A] (f g : A тЖТ тДЭ) :
    finiteMean (fun a тЖж f a + g a) = finiteMean f + finiteMean g := by
  unfold finiteMean
  rw [Finset.sum_add_distrib]
  ring

theorem finiteMean_sub {A : Type u} [Fintype A] (f g : A тЖТ тДЭ) :
    finiteMean (fun a тЖж f a - g a) = finiteMean f - finiteMean g := by
  unfold finiteMean
  rw [Finset.sum_sub_distrib]
  ring

theorem finiteMean_const_mul {A : Type u} [Fintype A] (r : тДЭ) (f : A тЖТ тДЭ) :
    finiteMean (fun a тЖж r * f a) = r * finiteMean f := by
  unfold finiteMean
  rw [тЖР Finset.mul_sum]
  ring

theorem finiteMean_mono {A : Type u} [Fintype A] [Nonempty A]
    {f g : A тЖТ тДЭ} (h : тИА a, f a тЙд g a) : finiteMean f тЙд finiteMean g := by
  unfold finiteMean
  apply div_le_div_of_nonneg_right
  ┬╖ exact Finset.sum_le_sum fun a _ тЖж h a
  ┬╖ exact_mod_cast (Nat.zero_le (Fintype.card A))

/-- The uniform PMF on a nonempty finite type. -/
noncomputable def finiteUniformPMF (A : Type u) [Fintype A] [Nonempty A] : PMF A :=
  PMF.uniformOfFintype A

/-- The uniform PMF viewed as a measure on the canonical discrete
measurable space. -/
noncomputable def finiteUniformMeasure (A : Type u) [Fintype A] [Nonempty A] :
    @MeasureTheory.Measure A тКд :=
  @PMF.toMeasure A тКд (finiteUniformPMF A)

/-- Integration against the uniform PMF is exactly normalized finite
averaging. -/
theorem integral_finiteUniformPMF_eq_finiteMean
    {A : Type u} [Fintype A] [Nonempty A] (f : A тЖТ тДЭ) :
    @MeasureTheory.integral A тДЭ _ _ тКд (finiteUniformMeasure A) f = finiteMean f := by
  letI : MeasurableSpace A := тКд
  unfold finiteUniformMeasure
  rw [PMF.integral_eq_sum]
  simp only [finiteUniformPMF, PMF.uniformOfFintype_apply, ENNReal.toReal_inv,
    ENNReal.toReal_natCast, smul_eq_mul, finiteMean]
  rw [тЖР Finset.mul_sum]
  have hcard : (Fintype.card A : тДЭ) тЙа 0 := by
    exact_mod_cast Fintype.card_ne_zero
  field_simp

/-! ## Dependent finite products -/

/-- Uniform averaging on a dependent finite product. -/
noncomputable def blockMean {n : тДХ} (Omega : Fin n тЖТ Type u)
    [тИА i, Fintype (Omega i)] (f : (тИА i, Omega i) тЖТ тДЭ) : тДЭ :=
  finiteMean f

/-- Uniform PMF on a dependent finite product. -/
noncomputable def blockUniformPMF {n : тДХ} (Omega : Fin n тЖТ Type u)
    [тИА i, Fintype (Omega i)] [тИА i, Nonempty (Omega i)] : PMF (тИА i, Omega i) :=
  finiteUniformPMF (тИА i, Omega i)

/-- The product-uniform PMF as a measure on the canonical discrete product
space. -/
noncomputable def blockUniformMeasure {n : тДХ} (Omega : Fin n тЖТ Type u)
    [тИА i, Fintype (Omega i)] [тИА i, Nonempty (Omega i)] :
    @MeasureTheory.Measure (тИА i, Omega i) тКд :=
  @PMF.toMeasure (тИА i, Omega i) тКд (blockUniformPMF Omega)

@[simp]
theorem blockMean_zero (Omega : Fin 0 тЖТ Type u) [тИА i, Fintype (Omega i)]
    (f : (тИА i, Omega i) тЖТ тДЭ) :
    blockMean Omega f = f (fun i тЖж Fin.elim0 i) := by
  unfold blockMean finiteMean
  rw [show Fintype.card (тИА i, Omega i) = 1 by simp, Nat.cast_one, div_one]
  calc
    тИС x, f x = f (fun i тЖж Fin.elim0 i) := by
      convert Fintype.sum_unique f using 1
      exact congrArg f (Subsingleton.elim _ _)

/-- Decomposition of the product mean into the head-block mean of the tail
means. -/
theorem blockMean_succ {n : тДХ} (Omega : Fin (n + 1) тЖТ Type u)
    [тИА i, Fintype (Omega i)] [тИА i, Nonempty (Omega i)]
    (f : (тИА i, Omega i) тЖТ тДЭ) :
    blockMean Omega f =
      finiteMean (fun a : Omega 0 тЖж
        blockMean (fun i : Fin n тЖж Omega i.succ) (fun x тЖж f (Fin.cons a x))) := by
  unfold blockMean finiteMean
  have hsum :
      (тИС x : тИА i, Omega i, f x) =
        тИС a : Omega 0, тИС x : тИА i : Fin n, Omega i.succ, f (Fin.cons a x) := by
    rw [тЖР (Fin.consEquiv Omega).sum_comp f, Fintype.sum_prod_type]
    simp [Fin.consEquiv]
  have hcard : Fintype.card (тИА i, Omega i) =
      Fintype.card (Omega 0) * Fintype.card (тИА i : Fin n, Omega i.succ) := by
    calc
      Fintype.card (тИА i, Omega i) =
          Fintype.card (Omega 0 ├Ч (тИА i : Fin n, Omega i.succ)) :=
        Fintype.card_congr (Fin.consEquiv Omega).symm
      _ = _ := Fintype.card_prod _ _
  rw [hsum, hcard]
  have hHead : (Fintype.card (Omega 0) : тДЭ) тЙа 0 := by
    exact_mod_cast Fintype.card_ne_zero
  have hTail : (Fintype.card (тИА i : Fin n, Omega i.succ) : тДЭ) тЙа 0 := by
    exact_mod_cast Fintype.card_ne_zero
  push_cast
  rw [тЖР Finset.sum_div]
  field_simp [hHead, hTail]

/-- Product-space expectation agrees with the normalized product mean. -/
theorem integral_blockUniformPMF_eq_blockMean {n : тДХ}
    (Omega : Fin n тЖТ Type u) [тИА i, Fintype (Omega i)]
    [тИА i, Nonempty (Omega i)] (f : (тИА i, Omega i) тЖТ тДЭ) :
    @MeasureTheory.integral (тИА i, Omega i) тДЭ _ _ тКд
        (blockUniformMeasure Omega) f = blockMean Omega f := by
  exact integral_finiteUniformPMF_eq_finiteMean f

/-- Coordinatewise oscillation for dependent blocks. -/
def HasBlockOscillation {n : тДХ} {Omega : Fin n тЖТ Type u}
    (f : (тИА i, Omega i) тЖТ тДЭ) (c : Fin n тЖТ тДЭтЙе0) : Prop :=
  тИА i x y, (тИА j, j тЙа i тЖТ x j = y j) тЖТ |f x - f y| тЙд (c i : тДЭ)

namespace HasBlockOscillation

theorem tail {n : тДХ} {Omega : Fin (n + 1) тЖТ Type u}
    {f : (тИА i, Omega i) тЖТ тДЭ} {c : Fin (n + 1) тЖТ тДЭтЙе0}
    (h : HasBlockOscillation f c) (a : Omega 0) :
    HasBlockOscillation (fun x тЖж f (Fin.cons a x)) (fun i тЖж c i.succ) := by
  intro i x y hxy
  apply h i.succ (Fin.cons a x) (Fin.cons a y)
  intro j hj
  cases j using Fin.cases with
  | zero => simp
  | succ k =>
      simp only [Fin.cons_succ]
      apply hxy k
      exact fun hki тЖж hj (congrArg Fin.succ hki)

theorem head {n : тДХ} {Omega : Fin (n + 1) тЖТ Type u}
    {f : (тИА i, Omega i) тЖТ тДЭ} {c : Fin (n + 1) тЖТ тДЭтЙе0}
    (h : HasBlockOscillation f c) (a b : Omega 0)
    (x : тИА i : Fin n, Omega i.succ) :
    |f (Fin.cons a x) - f (Fin.cons b x)| тЙд (c 0 : тДЭ) := by
  apply h 0 (Fin.cons a x) (Fin.cons b x)
  intro j hj
  cases j using Fin.cases with
  | zero => exact (hj rfl).elim
  | succ k => simp

end HasBlockOscillation

/-! ## Variance proxy and the finite head-block estimate -/

/-- The bounded-differences variance proxy `тИС i, c i┬▓ / 4`. -/
noncomputable def blockVariance {n : тДХ} (c : Fin n тЖТ тДЭтЙе0) : тДЭтЙе0 :=
  тИС i, (c i / 2) ^ 2

private theorem blockVariance_succ {n : тДХ} (c : Fin (n + 1) тЖТ тДЭтЙе0) :
    blockVariance c = (c 0 / 2) ^ 2 + blockVariance (fun i тЖж c i.succ) := by
  simp [blockVariance, Fin.sum_univ_succ]

theorem blockVariance_eq_sum_sq_div_four {n : тДХ} (c : Fin n тЖТ тДЭтЙе0) :
    (blockVariance c : тДЭ) = тИС i, (c i : тДЭ) ^ 2 / 4 := by
  rw [blockVariance]
  push_cast
  apply Finset.sum_congr rfl
  intro i _hi
  ring

/-- Hoeffding's lemma specialized to a uniformly distributed finite type,
with the interval length obtained from a pairwise oscillation bound. -/
private theorem finiteMean_exp_center_le_of_pairwise
    {A : Type u} [Fintype A] [Nonempty A]
    (m : A тЖТ тДЭ) (c : тДЭтЙе0)
    (hpair : тИА a b, |m a - m b| тЙд (c : тДЭ)) (t : тДЭ) :
    finiteMean (fun a тЖж Real.exp (t * (m a - finiteMean m))) тЙд
      Real.exp (((c : тДЭ) / 2) ^ 2 * t ^ 2 / 2) := by
  classical
  let values : Finset тДЭ := Finset.univ.image m
  have hvalues : values.Nonempty := by
    obtain тЯиaтЯй := (inferInstance : Nonempty A)
    exact тЯиm a, Finset.mem_image.mpr тЯиa, Finset.mem_univ _, rflтЯйтЯй
  let lo : тДЭ := values.min' hvalues
  have hloMem : lo тИИ values := Finset.min'_mem values hvalues
  obtain тЯиaтВА, _haтВА, haтВАтЯй := Finset.mem_image.mp hloMem
  have hbounds (a : A) : m a тИИ Set.Icc lo (lo + (c : тДЭ)) := by
    constructor
    ┬╖ exact Finset.min'_le values (m a)
        (Finset.mem_image.mpr тЯиa, Finset.mem_univ _, rflтЯй)
    ┬╖ have hdiff : m a - m aтВА тЙд (c : тДЭ) :=
        (le_abs_self (m a - m aтВА)).trans (hpair a aтВА)
      rw [haтВА] at hdiff
      linarith
  letI : MeasurableSpace A := тКд
  let mu : Measure A := finiteUniformMeasure A
  letI : IsProbabilityMeasure mu := by
    dsimp only [mu, finiteUniformMeasure]
    infer_instance
  have hm : AEMeasurable m mu := (measurable_of_finite m).aemeasurable
  have hb : тИАс╡Р a тИВmu, m a тИИ Set.Icc lo (lo + (c : тДЭ)) :=
    Filter.Eventually.of_forall hbounds
  have hsub := hasSubgaussianMGF_of_mem_Icc hm hb
  have hmgf := hsub.mgf_le t
  dsimp only [mu] at hmgf
  rw [ProbabilityTheory.mgf, integral_finiteUniformPMF_eq_finiteMean,
    integral_finiteUniformPMF_eq_finiteMean] at hmgf
  simpa using hmgf

private theorem abs_blockMean_head_sub_le {n : тДХ}
    {Omega : Fin (n + 1) тЖТ Type u} [тИА i, Fintype (Omega i)]
    [тИА i, Nonempty (Omega i)]
    {f : (тИА i, Omega i) тЖТ тДЭ} {c : Fin (n + 1) тЖТ тДЭтЙе0}
    (h : HasBlockOscillation f c) (a b : Omega 0) :
    |blockMean (fun i : Fin n тЖж Omega i.succ) (fun x тЖж f (Fin.cons a x)) -
        blockMean (fun i : Fin n тЖж Omega i.succ) (fun x тЖж f (Fin.cons b x))| тЙд
      (c 0 : тДЭ) := by
  let Omega' : Fin n тЖТ Type u := fun i тЖж Omega i.succ
  let fтВР : (тИА i, Omega' i) тЖТ тДЭ := fun x тЖж f (Fin.cons a x)
  let fB : (тИА i, Omega' i) тЖТ тДЭ := fun x тЖж f (Fin.cons b x)
  change |finiteMean fтВР - finiteMean fB| тЙд (c 0 : тДЭ)
  rw [тЖР finiteMean_sub]
  apply abs_le.mpr
  constructor
  ┬╖ calc
      -(c 0 : тДЭ) = finiteMean (fun _ : тИА i, Omega' i тЖж -(c 0 : тДЭ)) :=
        (finiteMean_const _).symm
      _ тЙд finiteMean (fun x тЖж fтВР x - fB x) := by
        apply finiteMean_mono
        intro x
        exact neg_le_of_abs_le (h.head a b x)
  ┬╖ calc
      finiteMean (fun x тЖж fтВР x - fB x) тЙд
          finiteMean (fun _ : тИА i, Omega' i тЖж (c 0 : тДЭ)) := by
        apply finiteMean_mono
        intro x
        exact (le_abs_self _).trans (h.head a b x)
      _ = (c 0 : тДЭ) := finiteMean_const _

/-! ## Product bounded differences -/

/-- Finite bounded differences in MGF form for arbitrary nonempty finite
uniform blocks. -/
theorem blockMean_exp_center_le (n : тДХ) :
    тИА (Omega : Fin n тЖТ Type u) [тИА i, Fintype (Omega i)]
      [тИА i, Nonempty (Omega i)]
      (f : (тИА i, Omega i) тЖТ тДЭ) (c : Fin n тЖТ тДЭтЙе0),
      HasBlockOscillation f c тЖТ тИА t : тДЭ,
        blockMean Omega (fun x тЖж Real.exp (t * (f x - blockMean Omega f))) тЙд
          Real.exp ((blockVariance c : тДЭ) * t ^ 2 / 2) := by
  induction n with
  | zero =>
      intro Omega instF instN f c h t
      simp only [blockMean_zero]
      simp [blockVariance]
  | succ n ih =>
      intro Omega instF instN f c h t
      let Omega' : Fin n тЖТ Type u := fun i тЖж Omega i.succ
      let c' : Fin n тЖТ тДЭтЙе0 := fun i тЖж c i.succ
      let fтВР : Omega 0 тЖТ (тИА i, Omega' i) тЖТ тДЭ :=
        fun a x тЖж f (Fin.cons a x)
      let m : Omega 0 тЖТ тДЭ := fun a тЖж blockMean Omega' (fтВР a)
      let R : тДЭ := Real.exp ((blockVariance c' : тДЭ) * t ^ 2 / 2)
      have hfmean : blockMean Omega f = finiteMean m := by
        simpa only [m, fтВР, Omega'] using blockMean_succ Omega f
      have htail (a : Omega 0) :
          blockMean Omega' (fun x тЖж Real.exp (t * (fтВР a x - m a))) тЙд R := by
        simpa only [m, R] using ih Omega' (fтВР a) c' (h.tail a) t
      have hbranch (a : Omega 0) :
          blockMean Omega'
              (fun x тЖж Real.exp (t * (fтВР a x - finiteMean m))) тЙд
            R * Real.exp (t * (m a - finiteMean m)) := by
        calc
          blockMean Omega'
              (fun x тЖж Real.exp (t * (fтВР a x - finiteMean m))) =
            blockMean Omega' (fun x тЖж
              Real.exp (t * (m a - finiteMean m)) *
                Real.exp (t * (fтВР a x - m a))) := by
              unfold blockMean
              apply finiteMean_congr
              intro x
              rw [тЖР Real.exp_add]
              congr 1
              ring
          _ = Real.exp (t * (m a - finiteMean m)) *
              blockMean Omega' (fun x тЖж Real.exp (t * (fтВР a x - m a))) := by
                exact finiteMean_const_mul _ _
          _ тЙд Real.exp (t * (m a - finiteMean m)) * R := by
                apply mul_le_mul_of_nonneg_left (htail a) (Real.exp_nonneg _)
          _ = R * Real.exp (t * (m a - finiteMean m)) := by ring
      have hmPair : тИА a b, |m a - m b| тЙд (c 0 : тДЭ) := by
        intro a b
        simpa only [m, fтВР, Omega'] using abs_blockMean_head_sub_le h a b
      have hhead := finiteMean_exp_center_le_of_pairwise m (c 0) hmPair t
      rw [blockMean_succ, hfmean]
      change finiteMean (fun a тЖж
          blockMean Omega' (fun x тЖж Real.exp (t * (fтВР a x - finiteMean m)))) тЙд _
      calc
        finiteMean (fun a тЖж
            blockMean Omega' (fun x тЖж Real.exp (t * (fтВР a x - finiteMean m)))) тЙд
          finiteMean (fun a тЖж R * Real.exp (t * (m a - finiteMean m))) := by
            exact finiteMean_mono hbranch
        _ = R * finiteMean (fun a тЖж Real.exp (t * (m a - finiteMean m))) :=
          finiteMean_const_mul _ _
        _ тЙд R * Real.exp (((c 0 : тДЭ) / 2) ^ 2 * t ^ 2 / 2) := by
          exact mul_le_mul_of_nonneg_left hhead (Real.exp_nonneg _)
        _ = Real.exp ((blockVariance c : тДЭ) * t ^ 2 / 2) := by
          rw [blockVariance_succ]
          push_cast
          rw [тЖР Real.exp_add]
          congr 1
          dsimp only [R, c']
          ring

/-! ## Measure-theoretic bridge and tails -/

/-- Expectation under the canonical discrete uniform product measure. -/
noncomputable def blockExpectation {n : тДХ} (Omega : Fin n тЖТ Type u)
    [тИА i, Fintype (Omega i)] [тИА i, Nonempty (Omega i)]
    (f : (тИА i, Omega i) тЖТ тДЭ) : тДЭ :=
  @MeasureTheory.integral (тИА i, Omega i) тДЭ _ _ тКд (blockUniformMeasure Omega) f

theorem blockExpectation_eq_blockMean {n : тДХ} (Omega : Fin n тЖТ Type u)
    [тИА i, Fintype (Omega i)] [тИА i, Nonempty (Omega i)]
    (f : (тИА i, Omega i) тЖТ тДЭ) :
    blockExpectation Omega f = blockMean Omega f := by
  exact integral_blockUniformPMF_eq_blockMean Omega f

/-- Bounded differences on arbitrary finite uniform blocks, with no MGF
premise.  The centering is the genuine expectation under the product-uniform
PMF. -/
