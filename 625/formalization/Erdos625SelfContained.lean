@[simp] private theorem residualEmbeddingRangeEquiv_val
    {X Y : Type*} [Fintype X] [Fintype Y] [DecidableEq Y]
    (f : X ↪ Y) (x : X) :
    (residualEmbeddingRangeEquiv f x).1 = f x := rfl

