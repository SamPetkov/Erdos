        (Finset.sum_le_sum_of_subset_of_nonneg
          (Finset.image_subset_iff.mpr fun f _ =>
            Finset.mem_powerset.mpr <| Finset.subset_univ _)
          fun _ _ _ => Finset.prod_nonneg fun _ _ => hwC _)
