            Finset.card (Finset.filter (fun e => e.2 = b) (F \ D)) := by
      rw [тЖР Finset.card_union_of_disjoint]
      ┬╖ congr with e
        by_cases he : e тИИ D <;> aesop
      ┬╖ exact Finset.disjoint_left.mpr fun x hxтВБ hxтВВ =>
          Finset.mem_sdiff.mp (Finset.mem_filter.mp hxтВВ).1 |>.2
            (Finset.mem_filter.mp hxтВБ).1
    replace h_card_diff := congr_arg Even h_card_diff
    simp_all +decide [parity_simps]
    exact (h_card_diff.mp (hF.2 b)).mp (hD.2 b)

private lemma exists_minimal_even_subset
