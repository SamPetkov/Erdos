      simp only [Finset.sum_sub_distrib, Finset.sum_add_distrib,
        Finset.mul_sum]
    _ = (∑ i : Fin 4, p i * h i) + t * T -
          Real.log (partition h t) := by
      rw [hpMean, hpSum, mul_one]

