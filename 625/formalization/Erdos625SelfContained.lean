/-!
# Consequences of the full phase asymptotic

This module derives the manuscript consequences (2.3), (2.4), and (2.9)
from the endpoint-uniform expansion in `PhaseAsymptotic`.  The class sizes
are the actual natural-number floor phase `phaseNat n` and its natural
successor/predecessor operations; no real surrogate is substituted for them.
-/

namespace Erdos625

open Filter Asymptotics Set
open scoped ENNReal Topology

noncomputable section

/-! ## Vanishing of the phase-expansion error -/

theorem tendsto_sq_logLogOrder_div_logOrder_zero :
    Tendsto (fun n : тДХ тЖж logLogOrder n ^ 2 / logOrder n) atTop (ЁЭУЭ 0) := by
  have h : (fun n : тДХ тЖж logLogOrder n ^ 2) =o[atTop] logOrder := by
    simpa only [logLogOrder, Function.comp_def, id_eq] using
      (Real.isLittleO_pow_log_id_atTop (n := 2)).comp_tendsto tendsto_logOrder_atTop
  exact h.tendsto_div_nhds_zero

theorem phaseExpansionResidual_tendsto_zero :
    Tendsto phaseExpansionResidual atTop (ЁЭУЭ 0) :=
  phaseExpansionResidual_isBigO.trans_tendsto
    tendsto_sq_logLogOrder_div_logOrder_zero

private theorem tendsto_logLogOrder_div_logOrder_zero :
    Tendsto (fun n : тДХ тЖж logLogOrder n / logOrder n) atTop (ЁЭУЭ 0) :=
  logLogOrder_isLittleO_logOrder.tendsto_div_nhds_zero

private theorem tendsto_inv_logOrder_zero :
    Tendsto (fun n : тДХ тЖж (logOrder n)тБ╗┬╣) atTop (ЁЭУЭ 0) :=
  tendsto_logOrder_atTop.inv_tendsto_atTop

/-- The phase first moment has logarithmic exponent `phaseDelta`, uniformly
on the full integer-floor sequence. -/
theorem log_mu_phaseNat_div_logOrder_sub_phaseDelta_tendsto_zero :
    Tendsto (fun n : тДХ тЖж
      Real.log (mu n (phaseNat n)) / logOrder n - phaseDelta n)
      atTop (ЁЭУЭ 0) := by
  have hDeltaLog : Tendsto (fun n : тДХ тЖж
      phaseDelta n * (logLogOrder n / logOrder n)) atTop (ЁЭУЭ 0) := by
    apply bdd_le_mul_tendsto_zero
    ┬╖ exact Filter.Eventually.of_forall phaseDelta_nonneg
    ┬╖ exact Filter.Eventually.of_forall fun n тЖж (phaseDelta_lt_one n).le
    ┬╖ exact tendsto_logLogOrder_div_logOrder_zero
  have hLinearLog : Tendsto (fun n : тДХ тЖж
      (2 / q - 1 / 2 : тДЭ) * (logLogOrder n / logOrder n)) atTop (ЁЭУЭ 0) :=
    by
      simpa using tendsto_logLogOrder_div_logOrder_zero.const_mul
        (2 / q - 1 / 2 : тДЭ)
  obtain тЯиM, hMтЯй := exists_phaseK_abs_bound
  have hK : Tendsto (fun n : тДХ тЖж phaseK (phaseDelta n) / logOrder n)
      atTop (ЁЭУЭ 0) := by
    apply tendsto_bdd_div_atTop_nhds_zero (b := -M) (B := M)
    ┬╖ exact Filter.Eventually.of_forall fun n тЖж
        (neg_le_of_abs_le (hM _ тЯиphaseDelta_nonneg n, (phaseDelta_lt_one n).leтЯй))
    ┬╖ exact Filter.Eventually.of_forall fun n тЖж
        (le_of_abs_le (hM _ тЯиphaseDelta_nonneg n, (phaseDelta_lt_one n).leтЯй))
    ┬╖ exact tendsto_logOrder_atTop
  have hResidualDiv : Tendsto (fun n : тДХ тЖж
      phaseExpansionResidual n / logOrder n) atTop (ЁЭУЭ 0) := by
    simpa only [div_eq_mul_inv, zero_mul] using
      phaseExpansionResidual_tendsto_zero.mul tendsto_inv_logOrder_zero
  have hSum := ((hDeltaLog.neg.add hLinearLog).add hK).add hResidualDiv
  simp only [neg_zero, add_zero] at hSum
  refine hSum.congr' ?_
  filter_upwards [eventually_gt_atTop (1 : тДХ)] with n hn
  have hN : 0 < logOrder n := Real.log_pos (by exact_mod_cast hn)
  simp only [phaseExpansionResidual, phaseExpansionMain]
  field_simp [hN.ne']
  ring

/-! ## Exact logarithmic form of the adjacent-size ratio -/

theorem log_mu_succ_sub_log_mu {n s : тДХ} (hsv : s + 1 тЙд n) :
    Real.log (mu n (s + 1)) - Real.log (mu n s) =
      Real.log ((n - s : тДХ) : тДЭ) - Real.log ((s + 1 : тДХ) : тДЭ) -
        (s : тДЭ) * q := by
  have hsle : s тЙд n := by omega
  have hnsub : (((n - s : тДХ) : тДЭ)) тЙа 0 := by
    exact_mod_cast (show n - s тЙа 0 by omega)
  have hsadd : (((s + 1 : тДХ) : тДЭ)) тЙа 0 := by positivity
  have hquot : (((n - s : тДХ) : тДЭ) / ((s + 1 : тДХ) : тДЭ)) тЙа 0 :=
    div_ne_zero hnsub hsadd
  have hpow : (2 : тДЭ) ^ s тЙа 0 := by positivity
  calc
    Real.log (mu n (s + 1)) - Real.log (mu n s) =
        Real.log (mu n (s + 1) / mu n s) := by
          rw [Real.log_div (mu_ne_zero hsv) (mu_ne_zero hsle)]
    _ = Real.log
        ((((n - s : тДХ) : тДЭ) / ((s + 1 : тДХ) : тДЭ)) / (2 : тДЭ) ^ s) := by
          rw [mu_succ_div_identity hsle]
    _ = Real.log ((n - s : тДХ) : тДЭ) -
          Real.log ((s + 1 : тДХ) : тДЭ) - Real.log ((2 : тДЭ) ^ s) := by
          rw [Real.log_div hquot hpow, Real.log_div hnsub hsadd]
    _ = Real.log ((n - s : тДХ) : тДЭ) -
          Real.log ((s + 1 : тДХ) : тДЭ) - (s : тДЭ) * q := by
          rw [Real.log_pow]
          rfl

private theorem phaseNat_add_isLittleO_natCast (k : тДХ) :
    (fun n : тДХ тЖж ((phaseNat n + k : тДХ) : тДЭ)) =o[atTop]
      (fun n : тДХ тЖж (n : тДЭ)) := by
  have hPhase := phaseNat_isTheta_logOrder.1.trans_isLittleO
    logOrder_isLittleO_natCast
  have hConst : (fun _n : тДХ тЖж (k : тДЭ)) =o[atTop] (fun n : тДХ тЖж (n : тДЭ)) := by
    simpa only [Function.comp_def, id_eq] using
      (isLittleO_const_id_atTop (k : тДЭ)).comp_tendsto
        (tendsto_natCast_atTop_atTop (R := тДЭ))
  exact (hPhase.add hConst).congr_left fun n тЖж by push_cast; rfl

private theorem tendsto_log_natSub_phaseNat_add_div_logOrder_one (k : тДХ)
    (hRange : тИАс╢а n : тДХ in atTop, phaseNat n + k тЙд n) :
    Tendsto (fun n : тДХ тЖж
      Real.log (((n - (phaseNat n + k) : тДХ) : тДЭ)) / logOrder n)
      atTop (ЁЭУЭ 1) := by
  have hSmall := phaseNat_add_isLittleO_natCast k
  have hDiff : (fun n : тДХ тЖж
      (((n - (phaseNat n + k) : тДХ) : тДЭ)) - (n : тДЭ)) =o[atTop]
        (fun n : тДХ тЖж (n : тДЭ)) := by
    refine hSmall.neg_left.congr' ?_ Filter.EventuallyEq.rfl
    filter_upwards [hRange] with n hn
    rw [Nat.cast_sub hn]
    push_cast
    ring
  have hEq : (fun n : тДХ тЖж (((n - (phaseNat n + k) : тДХ) : тДЭ))) ~[atTop]
      (fun n : тДХ тЖж (n : тДЭ)) := hDiff.isEquivalent
  have hLogEq := hEq.log (tendsto_natCast_atTop_atTop (R := тДЭ))
  have hDenom : тИАс╢а n : тДХ in atTop, Real.log (n : тДЭ) тЙа 0 := by
    simpa only [logOrder] using tendsto_logOrder_atTop.eventually_ne_atTop 0
  have hRatio := (isEquivalent_iff_tendsto_one hDenom).mp hLogEq
  convert hRatio using 1
  ext n
  rfl

private theorem tendsto_log_scaledLogOrder_div_logOrder_zero :
    Tendsto (fun n : тДХ тЖж
      Real.log ((2 / q) * logOrder n) / logOrder n) atTop (ЁЭУЭ 0) := by
  have hScalePos : 0 < (2 / q : тДЭ) := div_pos (by norm_num) q_pos
  have hConst : Tendsto (fun n : тДХ тЖж
      Real.log (2 / q) * (logOrder n)тБ╗┬╣) atTop (ЁЭУЭ 0) :=
    by
      simpa using tendsto_inv_logOrder_zero.const_mul (Real.log (2 / q))
  have hSum := hConst.add tendsto_logLogOrder_div_logOrder_zero
  simp only [add_zero] at hSum
  refine hSum.congr' ?_
  filter_upwards [eventually_gt_atTop (1 : тДХ)] with n hn
  have hN : logOrder n тЙа 0 := (Real.log_pos (by exact_mod_cast hn)).ne'
  rw [Real.log_mul hScalePos.ne' hN]
  simp only [logLogOrder]
  field_simp [hN]

private theorem tendsto_log_phaseNat_add_div_logOrder_zero (k : тДХ) :
    Tendsto (fun n : тДХ тЖж
      Real.log (((phaseNat n + k : тДХ) : тДЭ)) / logOrder n)
      atTop (ЁЭУЭ 0) := by
  have hScaleTop : Tendsto (fun n : тДХ тЖж (2 / q) * logOrder n) atTop atTop :=
    tendsto_logOrder_atTop.const_mul_atTop (div_pos (by norm_num) q_pos)
  have hConst : (fun _n : тДХ тЖж (k : тДЭ)) =o[atTop]
      (fun n : тДХ тЖж (2 / q) * logOrder n) := by
    simpa only [Function.comp_def, id_eq] using
      (isLittleO_const_id_atTop (k : тДЭ)).comp_tendsto hScaleTop
  have hEq : (fun n : тДХ тЖж ((phaseNat n + k : тДХ) : тДЭ)) ~[atTop]
      (fun n : тДХ тЖж (2 / q) * logOrder n) := by
    apply (phaseNat_isEquivalent_scaled_logOrder.add_isLittleO hConst).congr_left
    exact Filter.Eventually.of_forall fun n тЖж by push_cast; rfl
  have hLogEq := hEq.log hScaleTop
  have hInvBigO : (fun n : тДХ тЖж (logOrder n)тБ╗┬╣) =O[atTop]
      (fun n : тДХ тЖж (logOrder n)тБ╗┬╣) := isBigO_refl _ _
  have hDivBigO := hLogEq.isBigO.mul hInvBigO
  have hDivBigO' : (fun n : тДХ тЖж
      Real.log (((phaseNat n + k : тДХ) : тДЭ)) / logOrder n) =O[atTop]
        (fun n : тДХ тЖж Real.log ((2 / q) * logOrder n) / logOrder n) := by
    exact hDivBigO.congr_left (fun n тЖж by simp [div_eq_mul_inv]) |>.congr_right
      (fun n тЖж by simp [div_eq_mul_inv])
  exact hDivBigO'.trans_tendsto tendsto_log_scaledLogOrder_div_logOrder_zero

private theorem tendsto_phaseNat_add_mul_q_div_logOrder_two (k : тДХ) :
    Tendsto (fun n : тДХ тЖж
      (((phaseNat n + k : тДХ) : тДЭ) * q) / logOrder n)
      atTop (ЁЭУЭ 2) := by
  have hScaleTop : Tendsto (fun n : тДХ тЖж (2 / q) * logOrder n) atTop atTop :=
    tendsto_logOrder_atTop.const_mul_atTop (div_pos (by norm_num) q_pos)
  have hDenom : тИАс╢а n : тДХ in atTop, (2 / q) * logOrder n тЙа 0 :=
    hScaleTop.eventually_ne_atTop 0
  have hRatio := (isEquivalent_iff_tendsto_one hDenom).mp
    phaseNat_isEquivalent_scaled_logOrder
  have hBase : Tendsto (fun n : тДХ тЖж
      ((phaseNat n : тДЭ) * q) / logOrder n) atTop (ЁЭУЭ 2) := by
    have h := hRatio.const_mul (2 : тДЭ)
    simp only [mul_one] at h
    refine h.congr' ?_
    filter_upwards [eventually_gt_atTop (1 : тДХ)] with n hn
    have hN : logOrder n тЙа 0 := (Real.log_pos (by exact_mod_cast hn)).ne'
    simp only [Pi.div_apply]
