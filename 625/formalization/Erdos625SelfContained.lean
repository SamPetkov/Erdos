    (unitInterval.toNNReal (unitInterval.symm halfProbability) : ENNReal) =
      1 / 2 := by
  rw [← ENNReal.toReal_eq_toReal_iff' ENNReal.coe_ne_top (by finiteness)]
  norm_num [halfProbability]

