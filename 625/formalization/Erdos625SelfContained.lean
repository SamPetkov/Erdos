    {A B : Type*} [Fintype A] [Fintype B]
    (row : A → ℕ) (col : B → ℕ) (hrowTotal : ∑ a, row a = 0) :
    (∑ a, ∑ b, configurationCellTheta row col 0 a b ^ 3) = 0 := by
