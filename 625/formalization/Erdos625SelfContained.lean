  have hTcard : T.card = (H.induce (↑S : Set V)).degree v := by
    rw [← SimpleGraph.card_neighborFinset_eq_degree]
    refine Finset.card_bij
      (fun w hw => (⟨w, (Finset.mem_filter.mp hw).1⟩ : ↥(↑S : Set V))) ?_ ?_ ?_
