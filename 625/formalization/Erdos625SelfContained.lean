          (n : тДЭ) ^ (1 / 3 : тДЭ)) :
    quarterChainIndependentBlockEvent n тКЖ
      quarterChainLinearColoringEvent C n := by
  intro G hG U
  have hUle : U.card тЙд n := by
    simpa using Finset.card_le_univ U
  have hNat :=
    chromaticNumberNat_induce_le_quarterChainGreedyColorCost
