        (U : тДЭтЙе0тИЮ) / (m : тДЭтЙе0тИЮ) :=
      normalizeThetaSquareBound eulerENNReal (col b : тДЭтЙе0тИЮ)
        (U : тДЭтЙе0тИЮ) m hm

/-- Uniform row-square bound after also using the row cap. -/
theorem sum_configurationCellTheta_sq_row_le_uniform
    {A B : Type*} [Fintype A] [Fintype B]
    (row : A тЖТ тДХ) (col : B тЖТ тДХ) (m U : тДХ) (a : A)
    (hm : 0 < m) (hrowCap : тИА a, row a тЙд U)
    (hcolCap : тИА b, col b тЙд U) (hcolTotal : тИС b, col b = m) :
    тИС b, configurationCellTheta row col m a b ^ 2 тЙд
      eulerENNReal ^ 2 * (U : тДЭтЙе0тИЮ) ^ 3 / (m : тДЭтЙе0тИЮ) := by
  calc
    тИС b, configurationCellTheta row col m a b ^ 2 тЙд
        eulerENNReal ^ 2 * (row a : тДЭтЙе0тИЮ) ^ 2 *
          (U : тДЭтЙе0тИЮ) / (m : тДЭтЙе0тИЮ) :=
      sum_configurationCellTheta_sq_row_le
        row col m U a hm hcolCap hcolTotal
