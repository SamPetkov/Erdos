        (profileDeficitAffineB alpha - lambda) * (alpha : тДЭ) +
          Real.log (profileDeficitPartition alpha lambda) := by
  rw [profileDualPartition_eq_deficitScaled,
    Real.log_mul (Real.exp_ne_zero _)
