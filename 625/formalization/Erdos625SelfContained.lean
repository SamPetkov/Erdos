theorem tsum_profileDeficitNaturalTerm_eq_sum_fin
    (alpha : ℕ) (lambda : ℝ) :
    (∑' d : ℕ, profileDeficitNaturalTerm alpha lambda d) =
      ∑ d : Fin alpha,
