        (m : тДЭтЙе0тИЮ) := by
      apply ENNReal.div_le_div
      ┬╖ have hr : (row a : тДЭтЙе0тИЮ) ^ 2 тЙд (U : тДЭтЙе0тИЮ) ^ 2 := by
          exact pow_le_pow_left' (by exact_mod_cast hrowCap a) 2
        calc
