        fun cell => q cell.1 cell.2).prod := by
  induction edges with
  | nil => rfl
  | cons edge tail ih =>
      obtain тЯиcell, hcellтЯй := hdecode edge (by simp)
      have htail : тИА e тИИ tail,
          тИГ c, orientedPairToCell e = some c := by
        intro e he
        exact hdecode e (by simp [he])
