          extendedGaussianPartition a tilt +
        (∑' d : ℕ, extendedGaussianNaturalTerm a tilt d) /
          extendedGaussianPartition a tilt = 1 := by
    rw [← add_div, ← extendedGaussianPartition]
    exact div_self (extendedGaussianPartition_ne_zero ha)
