  have h_capped_sum :
      (тИС x тИИ Finset.Icc 3 R,
        if x тЙд r then rewardIncrement x else 0) =
        тИС x тИИ Finset.Icc 3 r, rewardIncrement x := by
    rw [тЖР Finset.sum_filter, h_filter]
