theorem decorationLabel_val_of_eq
    {b n : ℕ} {k : ColoringProfile b}
    (P : ProfilePartition n k) (d : ProfileDecoration P)
    (s t : (ColoringProfile.sizes k).toFinset)
    (Bs : ProfilePartsOfSize P s.1)
    (Bt : ProfilePartsOfSize P t.1)
