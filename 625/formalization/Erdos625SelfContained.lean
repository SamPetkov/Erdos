  have hSumForm :
      (∑ i : Fin 4,
          (-p i * Real.log (p i) +
            p i * Real.log (weight h (tilt h T) i))) =
        -(∑ i : Fin 4, p i * Real.log (p i)) +
          ∑ i : Fin 4, p i * Real.log (weight h (tilt h T) i) := by
    rw [Finset.sum_add_distrib]
    congr 1
    rw [← Finset.sum_neg_distrib]
    apply Finset.sum_congr rfl
    intro i _hi
    ring
