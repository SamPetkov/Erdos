  have hm0 : (m : ℝ≥0∞) ≠ 0 := by
    exact_mod_cast (Nat.ne_of_gt hm)
  have hmt : (m : ℝ≥0∞) ≠ ∞ := ENNReal.natCast_ne_top m
  apply (ENNReal.eq_div_iff hm0 hmt).2
  rw [div_eq_mul_inv]
