then by the exponential of the total atom weight. -/
theorem finiteInjectiveFamily_product_exp_bound
    {F C : Type*}
    [Fintype F] [Fintype C] [DecidableEq C]
    (wF : F → ℝ) (wC : C → ℝ)
    (cycles : F → Finset C)
