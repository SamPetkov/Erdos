    intro y
    obtain тЯиx, rflтЯй := (residualEmbeddingRangeEquiv domain).surjective y
    simpa [residualEmbeddingImagePairing] using extension.2 xтЯй
  invFun extension := тЯиextension.1, by
    intro x
    simpa [residualEmbeddingImagePairing] using
      extension.2 (residualEmbeddingRangeEquiv domain x)тЯй
  left_inv extension := by
    apply Subtype.ext
    rfl
  right_inv extension := by
    apply Subtype.ext
    rfl

/-- Restrict a full matching extending an exposed pairing to the complements
of the exposed finite subsets. -/
private def restrictResidualMatching
    {L R : Type*}
    [Fintype L] [Fintype R] [DecidableEq L] [DecidableEq R]
    {S : Finset L} {T : Finset R} {exposed : (тЖСS) тЙГ (тЖСT)}
    (extension : MatchingExtensions S T exposed) :
    {x : L // x тИЙ S} тЙГ {y : R // y тИЙ T} where
  toFun x := тЯиextension.1 x.1, by
    intro hxT
    let y : тЖСT := тЯиextension.1 x.1, hxTтЯй
    let s : тЖСS := exposed.symm y
