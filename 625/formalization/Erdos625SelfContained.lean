theorem residualDegreeProfile_of_witness
    {A B : Type*}
    [Fintype A] [Fintype B] [DecidableEq A] [DecidableEq B]
    {demand : A тЖТ B тЖТ тДХ} {row : A тЖТ тДХ} {col : B тЖТ тДХ}
    (htotal : (тИС a, row a) = тИС b, col b)
    (witness : PrescribedDemandWitness demand row col) :
    (тИА a, residualRowDegree witness a тЙд row a) тИз
      (тИА b, residualColumnDegree witness b тЙд col b) тИз
      ((тИС a, residualRowDegree witness a) =
        тИС b, residualColumnDegree witness b) := by
  refine тЯи?_, ?_,
