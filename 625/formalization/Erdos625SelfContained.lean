  have hremain : ∀ B ∈ P.parts, (B \ T).Nonempty := by
    intro B hB
    obtain ⟨r, hrR, hrB⟩ := hRmeet B hB
    refine ⟨r, Finset.mem_sdiff.mpr ⟨hrB, ?_⟩⟩
    intro hrT
