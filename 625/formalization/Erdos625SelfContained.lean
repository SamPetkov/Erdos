      (Icc ((((тМКrтМЛ : тДд) - тМИNтМЙ : тДд) : тДЭ)) r))
    (hdiff : DifferentiableOn тДЭ F
      (Ioo ((((тМКrтМЛ : тДд) - тМИNтМЙ : тДд) : тДЭ)) r))
    (hlower : тИА x тИИ
      Ioo ((((тМКrтМЛ : тДд) - тМИNтМЙ : тДд) : тДЭ)) r,
      slope тЙд deriv F x)
