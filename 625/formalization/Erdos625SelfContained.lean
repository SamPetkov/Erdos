    тИГ witness : PrescribedDemandWitness demand row col,
      ExtendsPrescribedDemandWitness matching witness := by
  classical
  have hselect : тИА a b,
      тИГ s : Finset (Fin (row a)),
        s тКЖ Finset.univ.filter
          (fun stub : Fin (row a) тЖж (matching тЯиa, stubтЯй).1 = b) тИз
        s.card = demand a b := by
    intro a b
    apply Finset.exists_subset_card_eq
    simpa [configurationCellCount] using hEvent a b
  choose selected hsubset hcard using hselect
  have hlabel : тИА a b (stub : тЖС(selected a b)),
