    {L R : Type*}
    [Fintype L] [Fintype R] [DecidableEq L] [DecidableEq R]
    {S : Finset L} {T : Finset R} {exposed : (↑S) ≃ (↑T)}
    (extension : MatchingExtensions S T exposed) :
    {x : L // x ∉ S} ≃ {y : R // y ∉ T} where
  toFun x := ⟨extension.1 x.1, by
    intro hxT
