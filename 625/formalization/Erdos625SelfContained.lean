      typedPartialMatchingEdgeEmbedding
          (unlabelledSkeletonFibreToTypedPartialMatching L k ell S)
          ⟨i, j, r'⟩ =
        ((⟨i, r⟩, ⟨j, c⟩) :
          RowStub k × ColumnStub ell)
