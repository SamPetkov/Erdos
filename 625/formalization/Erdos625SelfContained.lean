namespace Erdos625

open scoped BigOperators ENNReal

noncomputable section

local instance fintypeActualResidualEvenEdgeFamilyENNRealExp
    {A B : Type*} [Fintype A] [Fintype B]
    [DecidableEq A] [DecidableEq B]
