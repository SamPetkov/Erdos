      finiteMean (fun x ↦ fₐ x - fB x) ≤
          finiteMean (fun _ : ∀ i, Omega' i ↦ (c 0 : ℝ)) := by
        apply finiteMean_mono
        intro x
        exact (le_abs_self _).trans (h.head a b x)
