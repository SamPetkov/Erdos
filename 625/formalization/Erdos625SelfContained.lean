    {A B : Type*} [Fintype A] [Fintype B]
    [DecidableEq A] [DecidableEq B]
    (cellCount : A -> B -> Nat) (M : Finset (A × B))
    (q : A -> B -> Real)
    (hM : IsBipartiteMatching M)
    (hq : ∀ a b, 0 ≤ q a b) :
    (∑ F : ActualResidualEvenEdgeFamily cellCount
