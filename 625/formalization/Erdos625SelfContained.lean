    obtain ⟨s, hs⟩ :
        ∃ s ⊆ simpleBipartiteCycles A B,
          F \ C = s.biUnion id ∧
            ∀ C₁ ∈ s, ∀ C₂ ∈ s, C₁ ≠ C₂ → Disjoint C₁ C₂ := by
      apply ih (F \ C)
      · simp_all +decide [Finset.ssubset_def, Finset.subset_iff]
        exact Exists.elim hC.2.2.1 fun x hx => ⟨_, _, hC.1 _ _ hx, hx⟩
