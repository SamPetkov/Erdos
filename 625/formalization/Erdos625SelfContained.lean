    (hr : r = r') (hv : v = v') (hw : w = w')
    (code : RelaxedBlockChainCode V L r v w) :
    RelaxedBlockChainCode V L r' v' w' := by
  subst r'
  subst v'
  subst w'
  exact code

@[simp]
theorem decodeRelaxedBlockCells_castRelaxedBlockChainCode
