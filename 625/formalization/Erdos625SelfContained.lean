            exact Finset.card_pos.mp (by omega)
          have hdiff : U \ I ⊂ U :=
            Finset.sdiff_ssubset hI₁ hI_nonempty
          convert ih (U \ I) hdiff using 1
          · congr 1
          · rw [Finset.card_sdiff_of_subset hI₁]
