    (hLambda :
      (fun n : тДХ тЖж Lambda n) =o[atTop]
        (fun n : тДХ тЖж (n : тДЭ) / (Real.log (n : тДЭ)) ^ 4)) :
    (fun n : тДХ тЖж
        Real.sqrt ((n : тДЭ) * Lambda n) / Real.log (n : тДЭ)) =o[atTop]
      (fun n : тДХ тЖж (n : тДЭ) / (Real.log (n : тДЭ)) ^ 3) := by
  refine Asymptotics.IsLittleO.of_bound fun c hc тЖж ?_
  have hLambdaBound := hLambda.bound (sq_pos_of_pos hc)
