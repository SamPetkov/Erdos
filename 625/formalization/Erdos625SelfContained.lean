/-- A graph statistic has vertex-deletion oscillation `c i` when its values
on two graphs differ by at most `c i` whenever deleting `i` makes the graphs
equal. -/
def HasVertexDeletionOscillation {n : тДХ} (F : LabeledGraph n тЖТ тДЭ)
    (c : Fin n тЖТ тДЭтЙе0) : Prop :=
  тИА i G H, G.induce {v | v тЙа i} = H.induce {v | v тЙа i} тЖТ
    |F G - F H| тЙд (c i : тДЭ)

/-- Vertex-deletion oscillation becomes coordinate oscillation under the exact
vertex-block encoding. -/
theorem HasVertexDeletionOscillation.hasBlockOscillation {n : тДХ}
    {F : LabeledGraph n тЖТ тДЭ} {c : Fin n тЖТ тДЭтЙе0}
    (h : HasVertexDeletionOscillation F c) :
    HasBlockOscillation (fun x : VertexBlocks n тЖж F (blocksToGraph x)) c := by
  intro i x y hxy
  exact h i (blocksToGraph x) (blocksToGraph y)
    (blocksToGraph_induce_away_eq hxy)

/-- The expectation of a graph statistic, expressed on the exact vertex-block
probability space. -/
noncomputable def randomGraphBlockExpectation {n : тДХ}
    (F : LabeledGraph n тЖТ тДЭ) : тДЭ :=
