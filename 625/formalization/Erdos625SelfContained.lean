    norm_num [profileClassSize, i0]
  have hSize1 : profileClassSize i1 = 2 := by
    norm_num [profileClassSize, i1]
  have hSizeNe : profileClassSize i0 тЙа profileClassSize i1 := by
    rw [hSize0, hSize1]
