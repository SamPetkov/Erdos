    (тИА b, тИС a, q a b тЙд kappa * (U : тДЭтЙе0тИЮ) ^ 3 / (m : тДЭтЙе0тИЮ)) := by
  have hm0 : (m : тДЭтЙе0тИЮ) тЙа 0 := by exact_mod_cast hm.ne'
  have hmt : (m : тДЭтЙе0тИЮ) тЙа тИЮ := ENNReal.natCast_ne_top m
  have hcancel (x : тДЭтЙе0тИЮ) :
      x / (m : тДЭтЙе0тИЮ) =
        (x * (m : тДЭтЙе0тИЮ)) / (m : тДЭтЙе0тИЮ) ^ 2 := by
    apply (ENNReal.eq_div_iff (pow_ne_zero 2 hm0) (by finiteness)).2
