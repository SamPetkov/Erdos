    F ((((тМКrтМЛ : тДд) - тМИNтМЙ : тДд) : тДЭ)) тЙд -slope * N := by
  set a : тДЭ := (((тМКrтМЛ : тДд) - тМИNтМЙ : тДд) : тДЭ) with ha
  have hint : interior (Icc a r) = Ioo a r := interior_Icc
  have hNle : N тЙд r - a := by
    have hFloor : (тМКrтМЛ : тДЭ) тЙд r := Int.floor_le r
    have hCeil : N тЙд (тМИNтМЙ : тДЭ) := Int.le_ceil N
