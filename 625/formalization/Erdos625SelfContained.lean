    0 < profileDualVariance b t := by
  have hbPos : 0 < b := lt_of_lt_of_le Nat.zero_lt_two hb
  have hOneLt : 1 < b := lt_of_lt_of_le Nat.one_lt_two hb
  let i0 : Fin b := тЯи0, hbPosтЯй
  let i1 : Fin b := тЯи1, hOneLtтЯй
