      Fintype.card (Fin n тЙГ ShapeSlot m) = Nat.factorial n := by
    simpa only [Fintype.card_fin] using Fintype.card_equiv eтВА
  obtain тЯиeтЯй := h
  have hprofileMul :
      Fintype.card (ProfilePartition n k) * D = Nat.factorial n := by
    calc
      Fintype.card (ProfilePartition n k) * D =
          Fintype.card (TotalProfileDecoration n k) := htotal.symm
      _ = Fintype.card (Fin n тЙГ ShapeSlot m) := Fintype.card_congr e
      _ = Nat.factorial n := hallEquiv
