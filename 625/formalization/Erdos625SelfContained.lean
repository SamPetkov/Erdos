namespace Erdos625

open scoped BigOperators ENNReal

noncomputable section

/-- A pointwise degree-square estimate gives both row and column kernel-norm
bounds `kappa * U^3 / m`. -/
theorem q_row_column_le_of_pointwise_degree_square
