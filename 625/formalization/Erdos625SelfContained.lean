        rw [Real.log_mul hsFactorial hdesc]
        ring
  have hdcast : (d : ℝ) = (alpha : ℝ) - (s : ℝ) := by
    dsimp [d]
    exact Nat.cast_sub hsize
  have hchoose :
      (alpha.choose 2 : ℝ) - (s.choose 2 : ℝ) =
        (d : ℝ) * (alpha : ℝ) - ((d : ℝ) ^ 2 + d) / 2 := by
    rw [Nat.cast_choose_two, Nat.cast_choose_two, hdcast]
