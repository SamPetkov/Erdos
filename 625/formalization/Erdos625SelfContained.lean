    ext x
    simp only [Set.mem_preimage, Set.mem_singleton_iff]
    constructor
    · intro hx
      rw [← hx]
      exact (graphToBlocks_blocksToGraph x).symm
    · intro hx
      rw [hx]
      exact blocksToGraph_graphToBlocks G
