    (hrowCap : тИА a, row a тЙд U) (hcolCap : тИА b, col b тЙд U)
    (hrowTotal : тИС a, row a = m) (hcolTotal : тИС b, col b = m) :
    (тИС a, тИС b, configurationCellTheta row col m a b ^ 3) тЙд
      eulerENNReal ^ 3 * (U : тДЭтЙе0тИЮ) ^ 4 / (m : тДЭтЙе0тИЮ) := by
