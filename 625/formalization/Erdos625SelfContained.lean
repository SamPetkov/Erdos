  let columnEmbedding : тИА a b, тЖС(selected a b) тЖк Fin (col b) :=
    fun a b тЖж
      { toFun := columnValue a b
        inj' := by
          intro x y hxy
          apply Subtype.ext
          have hmatched :
              matching тЯиa, x.1тЯй = matching тЯиa, y.1тЯй := by
            calc
              matching тЯиa, x.1тЯй = тЯиb, columnValue a b xтЯй :=
