      Fintype.card (PrescribedDemandWitness demand row col) =
        тИС rowAllocation : (тИА a, StubAllocation (row a) (demand a)),
          тИС colAllocation : (тИА b, StubAllocation (col b) (fun a тЖж demand a b)),
            Finset.univ.prod
