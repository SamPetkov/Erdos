theorem weighted_evenSubgraph_polymer_bound
    {A B : Type*} [Fintype A] [Fintype B]
    [DecidableEq A] [DecidableEq B]
    (q : A тЖТ B тЖТ тДЭ) (M : Finset (A ├Ч B))
