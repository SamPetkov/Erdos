      eulerENNReal / (m : ℝ≥0∞) :=
    ENNReal.inv_div (Or.inr hMtop) (Or.inr hMzero)
  have hquotient :
      (cellDegreePowerProduct demand row col : ℝ≥0∞) *
          (eulerENNReal / (m : ℝ≥0∞)) ^ totalDemand demand =
        (cellDegreePowerProduct demand row col : ℝ≥0∞) /
          (((m : ℝ≥0∞) / eulerENNReal) ^ totalDemand demand) := by
    calc
      (cellDegreePowerProduct demand row col : ℝ≥0∞) *
          (eulerENNReal / (m : ℝ≥0∞)) ^ totalDemand demand =
        (cellDegreePowerProduct demand row col : ℝ≥0∞) *
          (((m : ℝ≥0∞) / eulerENNReal) ^ totalDemand demand)⁻¹ := by
        rw [← hinv, ← ENNReal.inv_pow]
