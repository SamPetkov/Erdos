    (row : A тЖТ тДХ) (col : B тЖТ тДХ) (q : A тЖТ B тЖТ тДЭтЙе0тИЮ)
    (U m : тДХ) (kappa : тДЭтЙе0тИЮ)
    (hm : 0 < m)
    (hrowTotal : тИС a, row a = m)
    (hcolTotal : тИС b, col b = m)
    (hrowCap : тИА a, row a тЙд U)
    (hcolCap : тИА b, col b тЙд U)
    (hq : тИА a b,
      q a b тЙд
        kappa * (row a : тДЭтЙе0тИЮ) ^ 2 * (col b : тДЭтЙе0тИЮ) ^ 2 /
          (m : тДЭтЙе0тИЮ) ^ 2) :
