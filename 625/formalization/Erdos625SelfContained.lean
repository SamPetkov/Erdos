    тЯиatom.1, atom.2.1, (witness.2.2 atom.1 atom.2.1).symm atom.2.2тЯй
  left_inv atom := by
    obtain тЯиa, b, stubтЯй := atom
    simp
  right_inv atom := by
    obtain тЯиa, b, stubтЯй := atom
    simp

/-- Distinct witness row atoms use distinct global row stubs. -/
def witnessRowEmbedding
    {A B : Type*}
    [Fintype A] [Fintype B] [DecidableEq A] [DecidableEq B]
    {demand : A тЖТ B тЖТ тДХ} {row : A тЖТ тДХ} {col : B тЖТ тДХ}
    (witness : PrescribedDemandWitness demand row col) :
    WitnessRowAtom witness тЖк RowStub row where
  toFun atom := тЯиatom.1, atom.2.2.1тЯй
  inj' := by
    rintro тЯиa, b, stubтЯй тЯиa', b', stub'тЯй h
