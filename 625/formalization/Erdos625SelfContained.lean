      (Finset.prod_congr rfl (fun a _ тЖж
        card_stubAllocation_mul_factorials (row a) (demand a)))
      (Finset.prod_congr rfl (fun b _ тЖж
        card_stubAllocation_mul_factorials (col b) (fun a тЖж demand a b))) using 1
