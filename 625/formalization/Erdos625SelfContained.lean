  refine (h.congr ?_).congr_right ?_
  ┬╖ filter_upwards [eventually_gt_atTop d] with alpha halpha
    intro lambda _
    change
      Real.exp
          (lambda * (d : тДЭ) +
            (Real.log (alpha.descFactorial d : тДЭ) -
                (d : тДЭ) * Real.log (alpha : тДЭ) -
              q / 2 * (d : тДЭ) ^ 2)) =
        profileDeficitNaturalTerm alpha lambda d
    rw [profileDeficitNaturalTerm_eq_of_lt alpha lambda d halpha]
    congr 1
    ring
  ┬╖ intro lambda _
    change
      Real.exp (lambda * (d : тДЭ) + -(q / 2 * (d : тДЭ) ^ 2)) =
        Real.exp
          (lambda * (d : тДЭ) - Real.log 2 / 2 * (d : тДЭ) ^ 2)
    unfold q
    congr 1

/-- Multiplication by a fixed real scalar preserves uniform convergence. -/
theorem tendstoUniformlyOn_const_mul_real
    {X : Type*} {K : Set X} {F : тДХ тЖТ X тЖТ тДЭ} {f : X тЖТ тДЭ}
    (h : TendstoUniformlyOn F f atTop K) (c : тДЭ) :
