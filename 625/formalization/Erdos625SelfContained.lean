  rw [coe_card_actualResidualEvenEdgeSets_eq_two_pow_cycleRank]
  simp_rw [residualReward_eq_localSignRewardNat]
  exact_mod_cast (show
    (∏ a : A, ∏ b : B,
      localSignRewardNat (configurationCellCount matching a b)) * 2 ^ rank ≤
        2 ^ (U * m / 2) by
      simpa only [mul_comm] using hdet)

