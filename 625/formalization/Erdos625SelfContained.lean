    {mean : тДЭ тЖТ тДЭ} {M target tilt : тДЭ}
    (hmono : StrictMono mean)
    (hleft : mean (-M) < target) (hright : target < mean M)
    (heq : mean tilt = target) :
    tilt тИИ Ioo (-M) M := by
  constructor
  ┬╖ apply hmono.lt_iff_lt.mp
    rw [heq]
