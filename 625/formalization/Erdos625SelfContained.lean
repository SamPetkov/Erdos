allows arbitrary zero coordinates. -/
theorem entropy_score_le_log_partition_sub_tilt_mul_target
    (h p : Fin 4 → ℝ) {T : ℝ}
    (hT : T ∈ Set.Ioo (2 : ℝ) 5)
    (hp : ∀ i, 0 ≤ p i)
    (hpSum : ∑ i : Fin 4, p i = 1)
    (hpMean : ∑ i : Fin 4, p i * support i = T) :
    -(∑ i : Fin 4, p i * Real.log (p i)) +
