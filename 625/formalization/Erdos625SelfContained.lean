theorem sum_residualCycleTraversalCode_weight_le_walkMass
    {A B : Type*} [Fintype A] [Fintype B]
    [DecidableEq A] [DecidableEq B]
    (q : A тЖТ B тЖТ ENNReal) :
    (тИС code : ResidualCycleTraversalCode A B, code.weight q) тЙд
      тИС a : A, тИС k : Fin (Fintype.card (A тКХ B)),
        finiteKernelWalkMass (bipartiteCellKernel q)
