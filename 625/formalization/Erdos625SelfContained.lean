    intro x
    simpa [residualEmbeddingImagePairing] using
      extension.2 (residualEmbeddingRangeEquiv domain x)⟩
  left_inv extension := by
    apply Subtype.ext
    rfl
  right_inv extension := by
    apply Subtype.ext
    rfl

