        (blocksToGraph_adj_lower _ _ _).symm
      _ тЖФ (blocksToGraph y).Adj u v := by
        rw [hva, SimpleGraph.adj_comm]

/-- Equivalently, deleting the affected vertex makes the two decoded graphs
literally equal. -/
theorem blocksToGraph_induce_away_eq {n : тДХ} {x y : VertexBlocks n}
    {i : Fin n} (hxy : тИА j, j тЙа i тЖТ x j = y j) :
    (blocksToGraph x).induce {v | v тЙа i} =
      (blocksToGraph y).induce {v | v тЙа i} := by
  ext u v
