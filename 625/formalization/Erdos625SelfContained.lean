      (fun x : тДЭ тЖж (Real.log x ^ 4 / x)тБ╗┬╣) atTop atTop at hInv
    simpa only [inv_div] using hInv
  have hBaseNat : Tendsto amplificationBase atTop atTop := by
    have hComp :=
      hBaseReal.comp (tendsto_natCast_atTop_atTop (R := тДЭ))
    change Tendsto
      (fun n : тДХ тЖж (n : тДЭ) / Real.log (n : тДЭ) ^ 4) atTop atTop at hComp
    change Tendsto
      (fun n : тДХ тЖж (n : тДЭ) / Real.log (n : тДЭ) ^ 4) atTop atTop
    exact hComp
