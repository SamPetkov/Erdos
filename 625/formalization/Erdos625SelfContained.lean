      (ENNReal.eq_div_iff hm0 hmt).1 rfl
    calc
      (m : тДЭтЙе0тИЮ) ^ 2 * (x / (m : тДЭтЙе0тИЮ)) =
          (m : тДЭтЙе0тИЮ) * ((m : тДЭтЙе0тИЮ) * (x / (m : тДЭтЙе0тИЮ))) := by ring
      _ = (m : тДЭтЙе0тИЮ) * x := by rw [hdiv]
      _ = x * (m : тДЭтЙе0тИЮ) := mul_comm _ _
