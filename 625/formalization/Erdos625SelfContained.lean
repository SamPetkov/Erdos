            (m : тДЭтЙе0тИЮ) ^ 2 := hcancel _
        _ = kappa * ((m : тДЭтЙе0тИЮ) ^ 2)тБ╗┬╣ *
            ((U : тДЭтЙе0тИЮ) ^ 3 * (m : тДЭтЙе0тИЮ)) := by
          rw [div_eq_mul_inv]
