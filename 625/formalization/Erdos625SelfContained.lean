    (delta lambda : Real)
    (hDeltaLower : 0 ≤ delta)
    (hDeltaUpper : delta ≤ 1)
    (hMean :
      ProfileEntropyS4.mean fourGaussianScore lambda = 1 + 2 / q - delta) :
    2 * q < lambda ∧ lambda < 9 * q / 2 := by
  apply uniform_four_size_tilt_corridor (1 + 2 / q - delta) lambda
  · linarith
  · linarith
  · exact hMean

