namespace Erdos625

open Filter MeasureTheory
open scoped Topology

noncomputable section

/-- The manuscript-form event from Lemma 10.1: one graph satisfies the same
linear-logarithmic chromatic bound for every induced vertex set. -/
def quarterChainLinearColoringEvent (C : тДЭ) (n : тДХ) :
    Set (LabeledGraph n) :=
  {G | тИА U : Finset (Fin n),
    (chromaticNumberNat (G.induce (U : Set (Fin n))) : тДЭ) тЙд
      C * (U.card : тДЭ) / Real.log (n : тДЭ) +
        (n : тДЭ) ^ (1 / 3 : тДЭ)}

