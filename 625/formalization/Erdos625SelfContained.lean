  rw [show extendedGaussianNaturalTerm a lambda d /
      extendedGaussianNaturalTerm a lambda k =
      Real.exp
        ((lambda * (d : ℝ) - a / 2 * (d : ℝ) ^ 2) -
          (lambda * (k : ℝ) - a / 2 * (k : ℝ) ^ 2)) by
