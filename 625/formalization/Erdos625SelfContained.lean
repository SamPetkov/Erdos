theorem sum_mul_sub_sum_mul_le
    (p h g : Fin 4 тЖТ тДЭ) {╬╡ : тДЭ}
    (hp : тИА i, 0 тЙд p i)
    (hpSum : тИС i : Fin 4, p i = 1)
    (hcoord : тИА i, h i - g i тЙд ╬╡) :
    (тИС i : Fin 4, p i * h i) - тИС i : Fin 4, p i * g i тЙд ╬╡ := by
  calc
    (тИС i : Fin 4, p i * h i) - тИС i : Fin 4, p i * g i =
        тИС i : Fin 4, p i * (h i - g i) := by
      rw [тЖР Finset.sum_sub_distrib]
      apply Finset.sum_congr rfl
      intro i _hi
      ring
    _ тЙд тИС i : Fin 4, p i * ╬╡ := by
      apply Finset.sum_le_sum
      intro i _hi
      exact mul_le_mul_of_nonneg_left (hcoord i) (hp i)
    _ = ╬╡ := by
      rw [тЖР Finset.sum_mul, hpSum, one_mul]

/-- **Finite-support value stability (the value part of (3.9)).**
For a fixed interior target, the optimized value is 1-Lipschitz in the
coordinatewise sup norm. -/
theorem abs_optimizedValue_sub_optimizedValue_le
    (h g : Fin 4 тЖТ тДЭ) {T ╬╡ : тДЭ}
    (hT : T тИИ Set.Ioo (2 : тДЭ) 5)
    (h╬╡ : 0 тЙд ╬╡)
    (hclose : тИА i, |h i - g i| тЙд ╬╡) :
    |optimizedValue h T - optimizedValue g T| тЙд ╬╡ := by
  have hhEq :=
    optimizer_entropy_score_eq_log_partition_sub_tilt_mul_target h hT
  have hgLe := entropy_score_le_log_partition_sub_tilt_mul_target
