    (hg0 : ∀ d, 0 ≤ g d)
    (hdom : ∀ n d x, x ∈ K → ‖f n d x‖ ≤ g d)
    (hdomF : ∀ d x, x ∈ K → ‖F d x‖ ≤ g d)
    (hcoord : ∀ d,
