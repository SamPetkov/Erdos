/-!
# Finite contingency-table feasibility tools

This module isolates the deterministic margin facts used before the
prescribed-cell probability estimate in manuscript Sections 6--9.  In
particular, an infeasible demand event is proved empty rather than silently
fed into a falling-factorial bound outside its valid range.
-/

open scoped BigOperators

namespace Erdos625

variable {A B : Type*} [Fintype A] [Fintype B]

/-- The total obtained by summing the rows of a finite table equals the total
obtained by summing its columns. -/
theorem sum_table_rows_eq_sum_table_columns
    (table : A тЖТ B тЖТ тДХ) :
    (тИС a, тИС b, table a b) = тИС b, тИС a, table a b := by
  rw [Finset.sum_comm]

/-- Entrywise demands bounded by a table have no more total mass than the
table. -/
theorem sum_demand_le_sum_table
    (demand table : A тЖТ B тЖТ тДХ)
    (hdemand : тИА a b, demand a b тЙд table a b) :
    (тИС a, тИС b, demand a b) тЙд тИС a, тИС b, table a b := by
  exact Finset.sum_le_sum fun a _ => Finset.sum_le_sum fun b _ => hdemand a b

/-- No nonnegative integer contingency table can realize infeasible row or
column demands.  The three impossible branches are: a demanded row exceeds
its row margin, a demanded column exceeds its column margin, or the two total
margin masses disagree. -/
theorem no_contingencyTable_of_infeasible_demands
    [DecidableEq A] [DecidableEq B]
    (demand : A тЖТ B тЖТ тДХ)
    (row : A тЖТ тДХ) (column : B тЖТ тДХ)
    (hbad :
      (тИГ a, row a < тИС b, demand a b) тИи
      (тИГ b, column b < тИС a, demand a b) тИи
      (тИС a, row a) тЙа тИС b, column b) :
    ┬м тИГ table : A тЖТ B тЖТ тДХ,
      (тИА a, (тИС b, table a b) = row a) тИз
      (тИА b, (тИС a, table a b) = column b) тИз
      тИА a b, demand a b тЙд table a b := by
  rintro тЯиtable, hrow, hcolumn, hdemandтЯй
  rcases hbad with hbadRow | hbadColumn | hbadTotal
  ┬╖ obtain тЯиa, haтЯй := hbadRow
    have hle : (тИС b, demand a b) тЙд тИС b, table a b :=
      Finset.sum_le_sum fun b _ => hdemand a b
    have : (тИС b, demand a b) тЙд row a := by
      simpa only [hrow a] using hle
    exact (Nat.not_lt_of_ge this) ha
  ┬╖ obtain тЯиb, hbтЯй := hbadColumn
    have hle : (тИС a, demand a b) тЙд тИС a, table a b :=
      Finset.sum_le_sum fun a _ => hdemand a b
    have : (тИС a, demand a b) тЙд column b := by
      simpa only [hcolumn b] using hle
    exact (Nat.not_lt_of_ge this) hb
  ┬╖ apply hbadTotal
    calc
      (тИС a, row a) = тИС a, тИС b, table a b := by
        apply Finset.sum_congr rfl
        intro a _
        exact (hrow a).symm
      _ = тИС b, тИС a, table a b := sum_table_rows_eq_sum_table_columns table
      _ = тИС b, column b := by
        apply Finset.sum_congr rfl
        intro b _
        exact hcolumn b

/-- If every row and column has mass at most `U`, cells with mass strictly
larger than `U / 2` form a matching.  This is the finite combinatorial claim
used to define the canonical high-cell skeleton in Section 8. -/
theorem highCells_form_matching
    [DecidableEq A] [DecidableEq B]
    (table : A тЖТ B тЖТ тДХ) (U : тДХ)
    (hrow : тИА a, (тИС b, table a b) тЙд U)
    (hcolumn : тИА b, (тИС a, table a b) тЙд U) :
    (тИА a bтВБ bтВВ,
      U / 2 < table a bтВБ тЖТ U / 2 < table a bтВВ тЖТ bтВБ = bтВВ) тИз
    (тИА b aтВБ aтВВ,
      U / 2 < table aтВБ b тЖТ U / 2 < table aтВВ b тЖТ aтВБ = aтВВ) := by
  constructor
  ┬╖ intro a bтВБ bтВВ hbтВБ hbтВВ
    by_contra hne
    have hpair :
        (тИС b тИИ ({bтВБ, bтВВ} : Finset B), table a b) тЙд тИС b, table a b :=
      Finset.sum_le_sum_of_subset (by simp)
    have htwo : table a bтВБ + table a bтВВ тЙд тИС b, table a b := by
      simpa [hne] using hpair
    have hle : table a bтВБ + table a bтВВ тЙд U := htwo.trans (hrow a)
    omega
  ┬╖ intro b aтВБ aтВВ haтВБ haтВВ
    by_contra hne
    have hpair :
        (тИС a тИИ ({aтВБ, aтВВ} : Finset A), table a b) тЙд тИС a, table a b :=
      Finset.sum_le_sum_of_subset (by simp)
    have htwo : table aтВБ b + table aтВВ b тЙд тИС a, table a b := by
      simpa [hne] using hpair
    have hle : table aтВБ b + table aтВВ b тЙд U := htwo.trans (hcolumn b)
    omega

