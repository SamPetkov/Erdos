    {V : Type*} [Fintype V] [DecidableEq V]
    (G : SimpleGraph V) [DecidableRel G.Adj]
    (cutoff block : ℕ) (hblock : 1 ≤ block)
    (hIndependent : ∀ S : Finset V, cutoff ≤ S.card →
      ∃ I : Finset V,
        I ⊆ S ∧ block ≤ I.card ∧ G.IsIndepSet (I : Set V)) :
