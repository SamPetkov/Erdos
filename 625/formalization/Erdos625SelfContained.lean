  · intro h x y hxy hcomplete
    rw [completeOn, SimpleGraph.map_adj] at hcomplete
    obtain ⟨x', y', hne, rfl, rfl⟩ := hcomplete
    exact h x'.property y'.property (by simpa using hne) hxy
