    {row : A тЖТ тДХ} {col : B тЖТ тДХ}
    (matching : ConfigurationMatching row col)
    (M : A тЖТ B тЖТ Prop)
    (hRowMatching : тИА a bтВБ bтВВ, M a bтВБ тЖТ M a bтВВ тЖТ bтВБ = bтВВ) :
