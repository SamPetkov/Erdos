/-! ## Variance proxy and the finite head-block estimate -/

/-- The bounded-differences variance proxy `∑ i, c i² / 4`. -/
noncomputable def blockVariance {n : ℕ} (c : Fin n → ℝ≥0) : ℝ≥0 :=
  ∑ i, (c i / 2) ^ 2

private theorem blockVariance_succ {n : ℕ} (c : Fin (n + 1) → ℝ≥0) :
