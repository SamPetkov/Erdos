    ext atom
    simp [f, witnessRowEmbedding]
  unfold witnessSelectedRowStubs
  rw [himage, Finset.card_image_of_injective, hfilter]
  ┬╖ rw [Finset.card_filter, Fintype.sum_sigma]
    have hinner : тИА x : A,
        (тИС y : (b : B) ├Ч тЖС((witness.1 x).1 b),
          if (тЯиx, yтЯй : WitnessRowAtom witness).1 = a then (1 : тДХ) else 0) =
          if x = a then (тИС b, demand x b) else 0 := by
      intro x
      by_cases hx : x = a
      ┬╖ subst x
        simp [Fintype.card_sigma, (witness.1 a).2.1]
      ┬╖ simp [hx]
    rw [Finset.sum_congr rfl (fun x _ => hinner x),
      Finset.sum_ite_eq' Finset.univ a (fun x => тИС b, demand x b)]
    simp
  ┬╖ exact f.injective

theorem card_selectedColumnStubs_in_class
    {A B : Type*} [Fintype A] [Fintype B]
    [DecidableEq A] [DecidableEq B]
    {demand : A тЖТ B тЖТ тДХ} {row : A тЖТ тДХ} {col : B тЖТ тДХ}
