  · rw [abs_div, abs_of_nonneg (by linarith : 0 ≤ B)]
    gcongr
  · rw [abs_div, abs_mul]
    gcongr
    · rwa [abs_sub_comm]
    · rw [abs_of_nonneg] <;> nlinarith

