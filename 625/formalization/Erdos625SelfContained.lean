  let matching : L ≃ R :=
    (Equiv.sumCompl (fun x : L ↦ x ∈ S)).symm |>.trans
      ((Equiv.sumCongr exposed residual).trans
        (Equiv.sumCompl (fun y : R ↦ y ∈ T)))
