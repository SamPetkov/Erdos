    {b n : ℕ} {k : ColoringProfile b}
    (P : ProfilePartition n k) (d : ProfileDecoration P)
    {B C : P.1.parts} (z : B.1) (w : C.1)
    (hBC : B = C) (hzw : z.1 = w.1) :
    (d.2 B z : ℕ) = (d.2 C w : ℕ) := by
  subst C
  have hsub : z = w := Subtype.ext hzw
  rw [hsub]

