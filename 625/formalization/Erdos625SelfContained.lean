              (U : тДЭтЙе0тИЮ)
          _ = eulerENNReal ^ 2 * (U : тДЭтЙе0тИЮ) ^ 3 := by ring
      ┬╖ rfl

/-- Uniform column-square bound after also using the column cap. -/
theorem sum_configurationCellTheta_sq_column_le_uniform
    {A B : Type*} [Fintype A] [Fintype B]
    (row : A тЖТ тДХ) (col : B тЖТ тДХ) (m U : тДХ) (b : B)
    (hm : 0 < m) (hrowCap : тИА a, row a тЙд U)
    (hcolCap : тИА b, col b тЙд U) (hrowTotal : тИС a, row a = m) :
    тИС a, configurationCellTheta row col m a b ^ 2 тЙд
      eulerENNReal ^ 2 * (U : тДЭтЙе0тИЮ) ^ 3 / (m : тДЭтЙе0тИЮ) := by
  calc
    тИС a, configurationCellTheta row col m a b ^ 2 тЙд
        eulerENNReal ^ 2 * (col b : тДЭтЙе0тИЮ) ^ 2 *
          (U : тДЭтЙе0тИЮ) / (m : тДЭтЙе0тИЮ) :=
      sum_configurationCellTheta_sq_column_le
        row col m U b hm hrowCap hrowTotal
    _ тЙд eulerENNReal ^ 2 * (U : тДЭтЙе0тИЮ) ^ 3 /
        (m : тДЭтЙе0тИЮ) := by
      apply ENNReal.div_le_div
      ┬╖ have hc : (col b : тДЭтЙе0тИЮ) ^ 2 тЙд (U : тДЭтЙе0тИЮ) ^ 2 := by
          exact pow_le_pow_left' (by exact_mod_cast hcolCap b) 2
        calc
          eulerENNReal ^ 2 * (col b : тДЭтЙе0тИЮ) ^ 2 * (U : тДЭтЙе0тИЮ) тЙд
              eulerENNReal ^ 2 * (U : тДЭтЙе0тИЮ) ^ 2 * (U : тДЭтЙе0тИЮ) :=
            mul_le_mul_left (mul_le_mul_right hc (eulerENNReal ^ 2))
              (U : тДЭтЙе0тИЮ)
          _ = eulerENNReal ^ 2 * (U : тДЭтЙе0тИЮ) ^ 3 := by ring
      ┬╖ rfl

/-! ## The global cubic bound -/

/-- Global cubic theta bound before cancelling m. -/
theorem sum_configurationCellTheta_cube_le_raw
    {A B : Type*} [Fintype A] [Fintype B]
    (row : A тЖТ тДХ) (col : B тЖТ тДХ) (m U : тДХ)
