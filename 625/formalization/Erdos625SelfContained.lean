  have h := hBase.add hConst
  simp only [add_zero] at h
  refine h.congr' ?_
  filter_upwards [eventually_gt_atTop (1 : тДХ)] with n hn
  have hN : logOrder n тЙа 0 := (Real.log_pos (by exact_mod_cast hn)).ne'
  push_cast
  field_simp [hN]

private theorem tendsto_log_mu_succ_increment_div_logOrder_neg_one (k : тДХ)
    (hRange : тИАс╢а n : тДХ in atTop, phaseNat n + k + 1 тЙд n) :
    Tendsto (fun n : тДХ тЖж
      (Real.log (mu n (phaseNat n + k + 1)) -
        Real.log (mu n (phaseNat n + k))) / logOrder n)
      atTop (ЁЭУЭ (-1)) := by
  have hRange' : тИАс╢а n : тДХ in atTop, phaseNat n + k тЙд n :=
    hRange.mono fun _n hn тЖж by omega
  have hNumerator :=
    tendsto_log_natSub_phaseNat_add_div_logOrder_one k hRange'
  have hClassSize := tendsto_log_phaseNat_add_div_logOrder_zero (k + 1)
  have hPower := tendsto_phaseNat_add_mul_q_div_logOrder_two k
  have h := (hNumerator.sub hClassSize).sub hPower
