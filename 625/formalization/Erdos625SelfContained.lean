  left_inv := by
    rintro ⟨v, rfl⟩
    simp
  right_inv := by
    intro i
    have h := equiv.apply_symm_apply (⟨b, i⟩ : Σ b, Fin (margin b))
    refine eq_of_heq ?_
    rw [eqRec_heq_iff_heq, h]

/-- Assemble a global sigma equivalence from a labeling and an ordering of
