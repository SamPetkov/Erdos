  calc
    mu.real ({╧Й | t тЙд X ╧Й} тИк {╧Й | t тЙд -X ╧Й}) тЙд
        mu.real {╧Й | t тЙд X ╧Й} + mu.real {╧Й | t тЙд -X ╧Й} :=
      measureReal_union_le _ _
    _ тЙд Real.exp (-t ^ 2 / (2 * c)) + Real.exp (-t ^ 2 / (2 * c)) := by
      gcongr
      ┬╖ exact hX.measure_ge_le ht
      ┬╖ simpa using hX.neg.measure_ge_le ht
