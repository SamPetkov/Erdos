          (тИС b, (col b : тДЭтЙе0тИЮ) ^ 2) тЙд
          (U : тДЭтЙе0тИЮ) ^ 2 * (тИС b, (col b : тДЭтЙе0тИЮ) * U) := by
        gcongr <;> norm_cast
        ┬╖ exact hrowCap a
        ┬╖ nlinarith only [hcolCap тА╣_тА║]
