        ∑ _p ∈ highCellFinset table R, (R + 1) := by
      rw [Finset.sum_const, smul_eq_mul]
    _ ≤ ∑ p ∈ highCellFinset table R, table p.1 p.2 := by
      apply Finset.sum_le_sum
      intro p hp
      have : R < table p.1 p.2 := by
        simpa [highCellFinset] using hp
