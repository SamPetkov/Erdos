  unfold edgeWeightOutside
  rw [← Finset.prod_biUnion]
  · rcongr e
    aesop
  · exact fun x hx y hy hxy =>
      Disjoint.mono Finset.sdiff_subset Finset.sdiff_subset
        (hdisj x hx y hy hxy)

/-- Equation (9.15), including both finite polymer-product and exponential
