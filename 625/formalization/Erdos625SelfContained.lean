      (fun N ↦ Real.log (extendedGaussianPartition a tilt) *
        extendedGaussianMassTruncation exceptional p N)
      atTop (nhds (Real.log (extendedGaussianPartition a tilt) * 1)) :=
    tendsto_const_nhds.mul hmass
