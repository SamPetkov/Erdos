open Filter
open scoped Topology

namespace Erdos625

/-- The deterministic scale `B_n = n / (log n)^4` from (10.10). -/
noncomputable def amplificationBase (n : тДХ) : тДЭ :=
  (n : тДЭ) / (Real.log (n : тДЭ)) ^ 4

/-- The deterministic, genuinely growing choice `r_n = sqrt B_n`. -/
noncomputable def amplificationRadius (n : тДХ) : тДЭ :=
  Real.sqrt (amplificationBase n)

/-- The unscaled target gap `n / (log n)^3`. -/
noncomputable def gapBase (n : тДХ) : тДЭ :=
  (n : тДЭ) / (Real.log (n : тДЭ)) ^ 3

/-- The complete deterministic amplification loss from (10.12). -/
noncomputable def amplificationError
    (C : тДЭ) (Lambda : тДХ тЖТ тДЭ) (n : тДХ) : тДЭ :=
  C *
    (Real.sqrt ((n : тДЭ) * Lambda n) / Real.log (n : тДЭ) +
      Real.sqrt ((n : тДЭ) * amplificationRadius n) /
        Real.log (n : тДЭ) +
      (n : тДЭ) ^ (1 / 3 : тДЭ) + 1)

/-- The deterministic radius used in the manuscript tends to infinity. -/
theorem amplificationRadius_tendsto_atTop :
    Tendsto amplificationRadius atTop atTop := by
  have hRatioZero :
      Tendsto (fun x : тДЭ тЖж Real.log x ^ 4 / x) atTop (ЁЭУЭ 0) := by
    simpa using
      (Real.tendsto_pow_log_div_mul_add_atTop 1 0 4 one_ne_zero)
  have hRatioPos :
      тИАс╢а x : тДЭ in atTop, 0 < Real.log x ^ 4 / x := by
    filter_upwards [eventually_gt_atTop (1 : тДЭ)] with x hx
    exact div_pos (pow_pos (Real.log_pos hx) 4) (by linarith)
  have hRatioWithin :
      Tendsto (fun x : тДЭ тЖж Real.log x ^ 4 / x) atTop (ЁЭУЭ[>] 0) :=
    tendsto_nhdsWithin_iff.mpr тЯиhRatioZero, hRatioPosтЯй
