  · filter_upwards [eventually_ge_atTop 2] with n hn
    have hn0 : (n : ℝ) ≠ 0 := by positivity
    have hlog : Real.log (n : ℝ) ≠ 0 := by
      exact ne_of_gt (Real.log_pos (Nat.one_lt_cast.mpr hn))
    rw [rootRoundingBudget]
    field_simp
    norm_num

