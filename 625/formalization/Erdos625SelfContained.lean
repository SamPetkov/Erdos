    fun b => le_trans (Finset.sum_le_sum fun a _ => hq a b) _тЯй
  ┬╖ simp +decide only [div_eq_mul_inv, mul_right_comm]
    simp +decide [тЖР Finset.mul_sum _ _ _, тЖР Finset.sum_mul]
    have h_simp : (row a : тДЭтЙе0тИЮ) ^ 2 *
