  ┬╖ intro i _
    exact mul_nonneg (profileDualWeight_pos hbPos t i).le (sq_nonneg _)
  ┬╖ by_cases h0 : profileClassSize i0 = profileDualMean b t
    ┬╖ have h1 : profileClassSize i1 тЙа profileDualMean b t := by
        intro h1
