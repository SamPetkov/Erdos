    [DecidableEq A] [DecidableEq B]
    {C M : Finset (A ├Ч B)} {code : SourceFreeCycleCutCode A B}
    (hcut : IsFaithfulCycleCut C M code) :
    ((relaxedBlockTransitionEdges code.chain).filterMap
