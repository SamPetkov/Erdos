            apply Finset.sum_congr rfl
            intro block hblock
            rw [Finset.mul_sum]
        _ =
            (тИС block : PositiveKernelThenTransitionCode V L v,
                block.weight K P x) *
              тИС tail : RelaxedBlockChainCode V L r x w,
                tail.weight K P := by
            rw [Finset.sum_mul]
        _ =
            finiteKernelComp (finitePositiveWalkKernel K L) P v x *
              finiteKernelEndpointMass
                (finiteKernelComp (finitePositiveWalkKernel K L) P) r x w := by
            rw [
              sum_positiveKernelThenTransitionCode_weight_eq_finiteKernelComp,
              ih x]

#print axioms
  sum_positiveKernelThenTransitionCode_weight_eq_finiteKernelComp
#print axioms
