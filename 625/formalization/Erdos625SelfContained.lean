    intro eps heps
    have habs : 0 < |c| := abs_pos.mpr hc
    have hE := h (eps / |c|) (div_pos heps habs)
    filter_upwards [hE] with n hn
    intro x hx
    have hnx := hn x hx
    rw [Real.dist_eq, ← mul_sub, abs_mul]
    rw [Real.dist_eq] at hnx
    calc
      |c| * |f x - F n x| < |c| * (eps / |c|) :=
        mul_lt_mul_of_pos_left hnx habs
      _ = eps := by field_simp

