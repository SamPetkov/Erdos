/-- For each allocation, the internal cell orderings contribute exactly the
product of the cell factorials. -/
theorem card_labeledStubAllocation
    {C : Type*} [Fintype C] [DecidableEq C]
    (m : тДХ) (demand : C тЖТ тДХ) :
    Fintype.card
