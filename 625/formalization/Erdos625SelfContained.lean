    {k : I -> Nat} {ell : J -> Nat}
    (S : UnlabelledTypedSkeleton k ell) (i : I) (j : J) : Nat :=
  (S.edges.filter (fun e => e.1.1 = i тИз e.2.1 = j)).card

/-- The physical edges in one fixed type cell, with the type indices removed
