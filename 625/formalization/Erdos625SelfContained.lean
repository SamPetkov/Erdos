          (((m : ℝ≥0∞) / eulerENNReal) ^ totalDemand demand) :=
        (ENNReal.div_eq_inv_mul).symm
  calc
    Finset.univ.prod (fun a ↦ Finset.univ.prod (fun b ↦
        configurationCellTheta row col m a b ^ demand a b /
          ((demand a b).factorial : ℝ≥0∞))) =
        (Finset.univ.prod (fun a ↦ Finset.univ.prod (fun b ↦
