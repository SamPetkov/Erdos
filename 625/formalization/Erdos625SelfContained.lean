      ∀ (U m₀ : ℕ),
        0 < m₀ →
        (n : ℝ) / Real.log (n : ℝ) ^ 6 ≤ (m₀ : ℝ) →
        (U : ℝ) ≤ 4 * (Real.log (n : ℝ) / Real.log 2) →
