    (S : Finset L) (T : Finset R) (exposed : (тЖСS) тЙГ (тЖСT)) :
    MatchingExtensions S T exposed тЙГ
      ({x : L // x тИЙ S} тЙГ {y : R // y тИЙ T}) where
  toFun := restrictResidualMatching
