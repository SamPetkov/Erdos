      constructor
      · exact hevent.1 a b
      · intro hab
        simpa using hevent.2 (a, b) hab
    · intro _ _
      rw [hR]
      omega
    · calc
        (∑ a, ∑ b, configurationCellCount matching a b) =
            ∑ p : A × B,
