  induction n with
  | zero => simp [h]
  | succ n ih =>
      simp only [cubeMean_succ]
      congr 2
      · exact ih (fun x => h (Fin.cons false x))
      · exact ih (fun x => h (Fin.cons true x))

@[simp]
theorem cubeMean_const {n : ℕ} (a : ℝ) :
    cubeMean (fun _ : Fin n → Bool => a) = a := by
  induction n with
  | zero => rfl
  | succ n ih => simp [cubeMean_succ, ih]

