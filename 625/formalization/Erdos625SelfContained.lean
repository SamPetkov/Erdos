        (2 * k.1 + 4) (Sum.inl a) (Sum.inl a) тЙд
        тИС w, finiteKernelEndpointMass (bipartiteCellKernel q)
          (2 * k.1 + 4) (Sum.inl a) w := by
      exact Finset.single_le_sum
        (s := Finset.univ)
        (f := fun w => finiteKernelEndpointMass (bipartiteCellKernel q)
