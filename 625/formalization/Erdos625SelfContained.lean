    have hinv :
        Tendsto (fun a : тДХ тЖж ((a : тДЭ) + 1)тБ╗┬╣) atTop (ЁЭУЭ 0) := by
      apply Tendsto.comp tendsto_inv_atTop_zero
      exact tendsto_natCast_atTop_atTop.atTop_add tendsto_const_nhds
