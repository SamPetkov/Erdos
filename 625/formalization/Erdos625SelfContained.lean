theorem existsAbsoluteResidualLambdaTotalBound :
    тИГ ╬║ : ENNReal, 0 < ╬║ тИз ╬║ тЙа тИЮ тИз
      тИА {A : Type u} {B : Type v} [Fintype A] [Fintype B]
          [DecidableEq A] [DecidableEq B]
          (M : Finset (A ├Ч B)) (U R m : тДХ)
