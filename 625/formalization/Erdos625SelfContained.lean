  simp only [demandFactorialProduct]
  rw [ennreal_inv_natCast_prod]
  · apply Finset.prod_congr rfl
    intro a ha
    rw [ennreal_inv_natCast_prod]
    intro b hb
    exact Nat.factorial_ne_zero _
  · intro a ha
    exact Finset.prod_ne_zero_iff.mpr (fun b hb ↦ Nat.factorial_ne_zero _)

