    {n p k b : ℕ} (G : LabeledGraph n) (P : VertexPartition n)
    (hproper : G ∈ partitionColoringEvent P)
    (hp : P.parts.card = p) (hpk : p ≤ k) (hkn : k ≤ n)
    (hbound : ∀ B ∈ P.parts, B.card ≤ b) :
    ∃ Q : VertexPartition n,
      Q.parts.card = k ∧ Q ≤ P ∧
