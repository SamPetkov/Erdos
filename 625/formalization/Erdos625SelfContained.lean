    {A B : Type*} [Fintype A] [DecidableEq A] [DecidableEq B]
    (F : Finset (A × B)) (b : B) : Finset A :=
  Finset.univ.filter fun a ↦ (a, b) ∈ F

/-- The zero-one incidence matrix of a finite bipartite edge set, with entries
in `ZMod 2`. -/
def bipartiteEdgeMatrix
