      (kappa * (m ^ 2 : тДЭтЙе0тИЮ)тБ╗┬╣) using 1
    ┬╖ rfl
    ┬╖ ring
    ┬╖ calc
        kappa * (m : тДЭтЙе0тИЮ)тБ╗┬╣ * (U : тДЭтЙе0тИЮ) ^ 3 =
            (kappa * (U : тДЭтЙе0тИЮ) ^ 3) / (m : тДЭтЙе0тИЮ) := by
          rw [div_eq_mul_inv]
