    {A B : Type*} [DecidableEq A] [DecidableEq B]
    (F : Finset (A × B)) (a : A) (b : B) :
    bipartiteEdgeMatrix F a b ≠ 0 ↔ (a, b) ∈ F := by
  simp [bipartiteEdgeMatrix]

