    [DecidableEq A] [DecidableEq B]
    {M : Finset (A ├Ч B)}
    (code : MarkedCycleTraversalCode A B M) :
    Fin (Fintype.card (A тКХ B)) :=
  code.2.1

/-- Underlying closed relaxed block chain. -/
def chain
    {A B : Type*} [Fintype A] [Fintype B]
    [DecidableEq A] [DecidableEq B]
    {M : Finset (A ├Ч B)}
