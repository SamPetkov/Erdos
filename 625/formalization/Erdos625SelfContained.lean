theorem card_targetFiber_eq_usedTarget_add_residual
    {X Y B : Type*} [Fintype X] [Fintype Y]
    [DecidableEq X] [DecidableEq Y] [DecidableEq B]
    (used : Finset X) (fullTarget : X тЖТ B) (b : B)
