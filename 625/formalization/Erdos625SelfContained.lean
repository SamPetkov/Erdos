theorem uniformOfFintype_prod_map_snd
    {alpha beta : Type*}
    [Fintype alpha] [Fintype beta] [Nonempty alpha] [Nonempty beta] :
    (PMF.uniformOfFintype (alpha ├Ч beta)).map
