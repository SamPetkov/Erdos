          sigma_eq_mk_sigmaSecondCast _ (hlabel a b x)
        _ = тЯиb, cтЯй := by rw [hx]
    have hmatchy : matching тЯиa', y.1тЯй = тЯиb, cтЯй := by
      calc
        matching тЯиa', y.1тЯй = тЯиb, columnValue a' b yтЯй :=
