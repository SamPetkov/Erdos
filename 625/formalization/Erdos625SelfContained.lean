    {b : ℕ} (hb : 0 < b) {n parts t : ℝ} (hparts : 0 < parts)
    (hmass : parts * profileDualMean b t = n)
    (x : RealColoringProfile b)
    (hx : RealColoringProfile.IsFeasible x n parts) :
