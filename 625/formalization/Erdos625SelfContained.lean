    ∑ i : Fin (alpha + 1), profileDeficitWeight alpha lambda i = 1 := by
  simp only [profileDeficitWeight]
  rw [← Finset.sum_div, profileDeficitPartition]
  exact div_self (profileDeficitPartition_pos alpha lambda).ne'

