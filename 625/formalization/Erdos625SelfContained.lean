    have hdisjoint : тИА cтВБ cтВВ, cтВБ тЙа cтВВ тЖТ Disjoint (cells cтВБ) (cells cтВВ) := by
      intro cтВБ cтВВ hne
      rw [Finset.disjoint_left]
      intro z hzтВБ hzтВВ
      simp only [cells, Finset.mem_image, Finset.mem_univ, true_and] at hzтВБ hzтВВ
      obtain тЯиiтВБ, hiтВБтЯй := hzтВБ
      obtain тЯиiтВВ, hiтВВтЯй := hzтВВ
