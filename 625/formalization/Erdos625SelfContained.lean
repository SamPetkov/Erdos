        Finset.univ.prod (fun c тЖж (demand c).factorial) := by
  have hcard : тИА allocation : StubAllocation m demand,
      Fintype.card (тИА c, Fin (demand c) тЙГ тЖС(allocation.1 c)) =
        тИП c, (demand c).factorial := by
    intro allocation
    convert Fintype.card_pi
    rw [Fintype.card_equiv]
    aesop
    exact Fintype.equivOfCardEq (by simp +decide [allocation.2.1])
  rw [Fintype.card_sigma,
    Finset.sum_congr rfl (fun allocation _ тЖж by simpa using hcard allocation)]
