section Erdos625SelfContained_Module_Erdos625_FallingFactorialBounds

/-!
# Lower bounds for descending factorials

This module proves the effective lower bound used in manuscript (6.10):
`(m / exp 1)^x тЙд m.descFactorial x` for `0 < m` and `x тЙд m`.

The finite core compares geometric means.  The top `x` factors in
`m.descFactorial x` have geometric mean at least that of all factors in `m!`,
which is encoded without roots as `(m!)^x тЙд ((m)_x)^m`.  Mathlib's effective
Stirling lower bound then supplies the constant `exp 1`.
-/

namespace Erdos625

open scoped ENNReal

/-- Every factor in `(m)_x` is at least `m-x+1`. -/
theorem pow_sub_add_one_le_descFactorial
    {m x : тДХ} (hx : x тЙд m) :
    (m - x + 1) ^ x тЙд m.descFactorial x := by
  induction x with
  | zero => simp
  | succ k ih =>
      have hk : k тЙд m := k.le_succ.trans hx
      have hbase : (m - k) ^ k тЙд (m - k + 1) ^ k :=
        Nat.pow_le_pow_left (Nat.le_succ _) _
      have hpow : (m - k) ^ k тЙд m.descFactorial k :=
        hbase.trans (ih hk)
      have hsub : m - (k + 1) + 1 = m - k := by omega
      simpa [Nat.descFactorial_succ, pow_succ', hsub] using
        Nat.mul_le_mul_left (m - k) hpow

/-- The geometric mean of the top `x` factors is at least the geometric mean
of all `m` factors, written without roots. -/
theorem factorial_pow_le_descFactorial_pow
    {m x : тДХ} (hx : x тЙд m) :
    m.factorial ^ x тЙд (m.descFactorial x) ^ m := by
  let r := m - x
  have hrx : r + x = m := Nat.sub_add_cancel hx
  have hbottom : r.factorial ^ x тЙд (m.descFactorial x) ^ r := by
    calc
      r.factorial ^ x тЙд (r ^ r) ^ x :=
        Nat.pow_le_pow_left r.factorial_le_pow _
      _ = r ^ (r * x) := by rw [pow_mul]
      _ тЙд (r + 1) ^ (x * r) := by
        rw [Nat.mul_comm r x]
        exact Nat.pow_le_pow_left (Nat.le_succ _) _
      _ = ((r + 1) ^ x) ^ r := by rw [pow_mul]
      _ тЙд (m.descFactorial x) ^ r := by
        apply Nat.pow_le_pow_left
        simpa [r] using pow_sub_add_one_le_descFactorial hx
  calc
    m.factorial ^ x = (r.factorial * m.descFactorial x) ^ x := by
      rw [Nat.factorial_mul_descFactorial hx]
    _ = r.factorial ^ x * (m.descFactorial x) ^ x := by rw [mul_pow]
    _ тЙд (m.descFactorial x) ^ r * (m.descFactorial x) ^ x :=
      Nat.mul_le_mul_right _ hbottom
    _ = (m.descFactorial x) ^ (r + x) := (pow_add _ _ _).symm
    _ = (m.descFactorial x) ^ m := by rw [hrx]

/-- Effective global falling-factorial lower bound, equation (6.10). -/
theorem real_div_exp_one_pow_le_descFactorial
    {m x : тДХ} (hm : 0 < m) (hx : x тЙд m) :
    ((m : тДЭ) / Real.exp 1) ^ x тЙд (m.descFactorial x : тДЭ) := by
  have hm_one : (1 : тДЭ) тЙд m := by exact_mod_cast hm
  have hsqrt : 1 тЙд Real.sqrt (2 * Real.pi * (m : тДЭ)) := by
    rw [Real.one_le_sqrt]
    have hpi := Real.pi_gt_three
    nlinarith
  have hbaseNonneg : 0 тЙд ((m : тДЭ) / Real.exp 1) ^ m := by positivity
  have hbase : ((m : тДЭ) / Real.exp 1) ^ m тЙд (m.factorial : тДЭ) := by
    calc
      ((m : тДЭ) / Real.exp 1) ^ m =
          1 * ((m : тДЭ) / Real.exp 1) ^ m := by rw [one_mul]
      _ тЙд Real.sqrt (2 * Real.pi * (m : тДЭ)) *
          ((m : тДЭ) / Real.exp 1) ^ m :=
        mul_le_mul_of_nonneg_right hsqrt hbaseNonneg
      _ тЙд (m.factorial : тДЭ) := Stirling.le_factorial_stirling m
  have hNat := factorial_pow_le_descFactorial_pow hx
  have hpow :
      (((m : тДЭ) / Real.exp 1) ^ x) ^ m тЙд
        ((m.descFactorial x : тДЭ)) ^ m := by
    calc
      (((m : тДЭ) / Real.exp 1) ^ x) ^ m =
          (((m : тДЭ) / Real.exp 1) ^ m) ^ x := by
        rw [тЖР pow_mul, тЖР pow_mul, Nat.mul_comm x m]
      _ тЙд ((m.factorial : тДЭ)) ^ x :=
        pow_le_pow_leftтВА hbaseNonneg hbase _
      _ тЙд ((m.descFactorial x : тДЭ)) ^ m := by
        exact_mod_cast hNat
  exact (pow_le_pow_iff_leftтВА (by positivity) (by positivity) hm.ne').mp hpow

/-- Euler's number, embedded in `тДЭтЙе0тИЮ`.  Naming this constant keeps the
configuration-model bound legible while retaining its exact value. -/
noncomputable def eulerENNReal : тДЭтЙе0тИЮ := ENNReal.ofReal (Real.exp 1)

/-- `тДЭтЙе0тИЮ` form of the effective falling-factorial lower bound (6.10). -/
theorem ennreal_div_euler_pow_le_descFactorial
    {m x : тДХ} (hm : 0 < m) (hx : x тЙд m) :
    ((m : тДЭтЙе0тИЮ) / eulerENNReal) ^ x тЙд
      (m.descFactorial x : тДЭтЙе0тИЮ) := by
  have h := ENNReal.ofReal_le_ofReal
    (real_div_exp_one_pow_le_descFactorial hm hx)
  have hbase : 0 тЙд (m : тДЭ) / Real.exp 1 :=
    div_nonneg (Nat.cast_nonneg _) (Real.exp_pos _).le
  rw [ENNReal.ofReal_pow hbase,
    ENNReal.ofReal_div_of_pos (Real.exp_pos 1),
    ENNReal.ofReal_natCast, ENNReal.ofReal_natCast] at h
  exact h

