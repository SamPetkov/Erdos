  apply residualActualAttachmentNumerator_le_of_forall_event_integrand_le
  intro matching hevent
  let rank := cycleRank
    (bipartiteGraph fun a b =>
      (a, b) ∈ M ∨ 2 ≤ configurationCellCount matching a b)
