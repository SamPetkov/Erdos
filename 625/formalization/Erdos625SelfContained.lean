      obtain тЯиe, heC, heMтЯй := h
      exact тЯиe, Finset.mem_inter.mpr тЯиheC, heMтЯйтЯй
    ┬╖ rintro тЯиe, heтЯй h
      exact (Finset.disjoint_left.mp h) (Finset.mem_inter.mp he).1
