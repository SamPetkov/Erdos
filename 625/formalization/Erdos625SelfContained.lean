theorem decodeRelaxedBlockCells_eq_union
    {A B : Type*} [DecidableEq A] [DecidableEq B]
    {L r : тДХ} {v w : A тКХ B}
    (code : RelaxedBlockChainCode (A тКХ B) L r v w) :
