  have hterm2 : 0 тЙд weight h t 2 * (support 2 - mean h t) ^ 2 :=
    mul_nonneg (weight_pos h t 2).le (sq_nonneg _)
  have hterm3 : 0 тЙд weight h t 3 * (support 3 - mean h t) ^ 2 :=
    mul_nonneg (weight_pos h t 3).le (sq_nonneg _)
