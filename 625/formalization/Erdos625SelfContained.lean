/-- The optimizer attains the dual value exactly. -/
theorem optimizer_entropy_score_eq_log_partition_sub_tilt_mul_target
    (h : Fin 4 → ℝ) {T : ℝ}
    (hT : T ∈ Set.Ioo (2 : ℝ) 5) :
