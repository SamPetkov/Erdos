        (Finset.univ.filter
          (fun x => x тИЙ used тИз fullTarget x = b)).card := by
    rw [тЖР Fintype.card_subtype, тЖР Fintype.card_subtype]
    exact Fintype.card_congr complementFiberEquiv.symm
