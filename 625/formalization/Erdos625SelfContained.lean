    RealColoringProfile.IsFeasible
      (profileDualOptimizer (b := b) parts t) n parts := by
  refine ⟨profileDualOptimizer_nonnegative hb hparts.le t,
    profileDualOptimizer_partCount hb parts t, ?_⟩
