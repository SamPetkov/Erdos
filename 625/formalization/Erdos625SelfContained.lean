          partialDiagonalFactorialMajorant xi ell := by
      apply Finset.sum_le_sum_of_subset_of_nonneg (Finset.filter_subset _ _)
      intro ell hell _
      exact partialDiagonalFactorialMajorant_nonneg xi hxi ell
