    {b n : тДХ} {k : ColoringProfile b}
    (P : ProfilePartition n k) (d : ProfileDecoration P) :
    Function.Injective (decoratedPartBlockIndexMap P d) :=
  (decoratedBlockIndexPartMap_leftInverse P d).injective

