  rcases lt_trichotomy u.val v.val with huv | huv | huv
  · let a : Fin v.val := ⟨u.val, huv⟩
    have hua : lowerVertex v a = u := Fin.ext rfl
    rw [← hua, blocksToGraph_adj_lower, blocksToGraph_adj_lower, hxy v hv]
