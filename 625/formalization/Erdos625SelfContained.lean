theorem quarterRecurrence_lowerBound (s : ℕ → ℝ)
    (hstep : ∀ t : ℕ, (s t - 1) / 4 ≤ s (t + 1)) :
    ∀ t : ℕ, (4 : ℝ)⁻¹ ^ t * s 0 - 1 / 3 ≤ s t := by
  intro t
  induction t with
  | zero => norm_num
  | succ t ih =>
      calc
        (4 : ℝ)⁻¹ ^ (t + 1) * s 0 - 1 / 3 =
            (((4 : ℝ)⁻¹ ^ t * s 0 - 1 / 3) - 1) / 4 := by
              ring
        _ ≤ (s t - 1) / 4 := by linarith
        _ ≤ s (t + 1) := hstep t

