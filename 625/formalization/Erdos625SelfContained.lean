section Erdos625SelfContained_Module_Erdos625_FinpartitionRefinement

/-!
# Exact refinements of finite partitions

This module supplies the deterministic splitting step used in manuscript
equation (4.5).  A finite partition with at most `k` nonempty parts can be
refined to one with exactly `k` nonempty parts whenever `k` does not exceed
the cardinality of the underlying finite set.

The construction is one-shot.  Reserve one representative in every old
part, choose the required number of other vertices, make the chosen vertices
singletons, and retain the nonempty residual of every old part.  This makes
the exact part count and all empty cases explicit.
-/

namespace Erdos625

open scoped BigOperators

/-! ## A singleton/residual refinement -/

/-- Refine `P` by making every element of `T` a singleton and replacing each
old part `B` by its residual `B \ T`.  The hypotheses say that `T` lies in the
partitioned set and that no old part is exhausted. -/
def singletonResidualRefinement {╬▒ : Type*} [DecidableEq ╬▒]
    {s T : Finset ╬▒} (P : Finpartition s) (hT : T тКЖ s)
    (hremain : тИА B тИИ P.parts, (B \ T).Nonempty) : Finpartition s := by
  apply Finpartition.ofExistsUnique
    (T.image (fun x => ({x} : Finset ╬▒)) тИк
      P.parts.image fun B => B \ T)
  ┬╖ intro A hA
    rw [Finset.mem_union] at hA
    rcases hA with hA | hA
    ┬╖ obtain тЯиx, hxT, rflтЯй := Finset.mem_image.mp hA
      exact Finset.singleton_subset_iff.mpr (hT hxT)
    ┬╖ obtain тЯиB, hB, rflтЯй := Finset.mem_image.mp hA
      exact Finset.sdiff_subset.trans (P.subset hB)
  ┬╖ intro x hx
    by_cases hxT : x тИИ T
    ┬╖ refine тЯи{x}, ?_, ?_тЯй
      ┬╖ exact тЯиFinset.mem_union_left _ <|
          Finset.mem_image.mpr тЯиx, hxT, rflтЯй, Finset.mem_singleton_self xтЯй
      ┬╖ intro A hA
        rcases hA with тЯиhApart, hxAтЯй
        rw [Finset.mem_union] at hApart
        rcases hApart with hAsing | hAres
        ┬╖ obtain тЯиy, hyT, rflтЯй := Finset.mem_image.mp hAsing
          simpa only [Finset.singleton_inj] using
            (Finset.eq_of_mem_singleton hxA).symm
        ┬╖ obtain тЯиB, hB, rflтЯй := Finset.mem_image.mp hAres
          exact False.elim ((Finset.mem_sdiff.mp hxA).2 hxT)
    ┬╖ let B := P.part x
      have hB : B тИИ P.parts := P.part_mem.mpr hx
      have hxB : x тИИ B := P.mem_part hx
      refine тЯиB \ T, ?_, ?_тЯй
      ┬╖ exact тЯиFinset.mem_union_right _ <|
          Finset.mem_image.mpr тЯиB, hB, rflтЯй,
          Finset.mem_sdiff.mpr тЯиhxB, hxTтЯйтЯй
      ┬╖ intro A hA
        rcases hA with тЯиhApart, hxAтЯй
        rw [Finset.mem_union] at hApart
        rcases hApart with hAsing | hAres
        ┬╖ obtain тЯиy, hyT, rflтЯй := Finset.mem_image.mp hAsing
          have hxy : x = y := Finset.mem_singleton.mp hxA
          exact False.elim (hxT (hxy тЦ╕ hyT))
        ┬╖ obtain тЯиC, hC, rflтЯй := Finset.mem_image.mp hAres
          have hpart : P.part x = C :=
            P.part_eq_of_mem hC (Finset.mem_sdiff.mp hxA).1
          exact congrArg (fun D : Finset ╬▒ => D \ T) hpart.symm
  ┬╖ intro hempty
    rw [Finset.mem_union] at hempty
    rcases hempty with hsing | hres
    ┬╖ obtain тЯиx, hxT, hxтЯй := Finset.mem_image.mp hsing
      exact Finset.singleton_ne_empty x hx
    ┬╖ obtain тЯиB, hB, hBemptyтЯй := Finset.mem_image.mp hres
      obtain тЯиx, hxтЯй := hremain B hB
      rw [hBempty] at hx
      simp at hx

@[simp] theorem parts_singletonResidualRefinement {╬▒ : Type*}
    [DecidableEq ╬▒] {s T : Finset ╬▒} (P : Finpartition s)
    (hT : T тКЖ s) (hremain : тИА B тИИ P.parts, (B \ T).Nonempty) :
    (singletonResidualRefinement P hT hremain).parts =
      T.image (fun x => ({x} : Finset ╬▒)) тИк
        P.parts.image (fun B => B \ T) :=
  rfl

/-- Every new singleton or residual part lies in an old part.  Recall that
the `Finpartition` order is the refinement order: `Q тЙд P` means that `Q`
refines `P`. -/
theorem singletonResidualRefinement_le {╬▒ : Type*} [DecidableEq ╬▒]
    {s T : Finset ╬▒} (P : Finpartition s) (hT : T тКЖ s)
    (hremain : тИА B тИИ P.parts, (B \ T).Nonempty) :
    singletonResidualRefinement P hT hremain тЙд P := by
  intro A hA
  rw [parts_singletonResidualRefinement, Finset.mem_union] at hA
  rcases hA with hAsing | hAres
  ┬╖ obtain тЯиx, hxT, rflтЯй := Finset.mem_image.mp hAsing
    refine тЯиP.part x, P.part_mem.mpr (hT hxT), ?_тЯй
    exact Finset.singleton_subset_iff.mpr (P.mem_part (hT hxT))
  ┬╖ obtain тЯиB, hB, rflтЯй := Finset.mem_image.mp hAres
    exact тЯиB, hB, Finset.sdiff_subsetтЯй

/-- The singleton family and the residual family are disjoint, and neither
family has collisions.  Consequently the refinement has exactly one new
part for every selected element in addition to one residual per old part. -/
theorem card_parts_singletonResidualRefinement {╬▒ : Type*}
    [DecidableEq ╬▒] {s T : Finset ╬▒} (P : Finpartition s)
    (hT : T тКЖ s) (hremain : тИА B тИИ P.parts, (B \ T).Nonempty) :
    (singletonResidualRefinement P hT hremain).parts.card =
      T.card + P.parts.card := by
  have hdisjoint : Disjoint (T.image (fun x => ({x} : Finset ╬▒)))
      (P.parts.image fun B => B \ T) := by
    rw [Finset.disjoint_left]
    intro A hAsing hAres
    obtain тЯиx, hxT, rflтЯй := Finset.mem_image.mp hAsing
    obtain тЯиB, hB, hEqтЯй := Finset.mem_image.mp hAres
    have hxres : x тИИ B \ T := by
      rw [hEq]
      exact Finset.mem_singleton_self x
    exact (Finset.mem_sdiff.mp hxres).2 hxT
  have hinj : Set.InjOn (fun B : Finset ╬▒ => B \ T) P.parts := by
    intro B hB C hC hEq
    obtain тЯиx, hxтЯй := hremain B hB
    have hxB : x тИИ B := (Finset.mem_sdiff.mp hx).1
    have hxT : x тИЙ T := (Finset.mem_sdiff.mp hx).2
    change B \ T = C \ T at hEq
    have hxCdiff : x тИИ C \ T := by
      rw [тЖР hEq]
      exact Finset.mem_sdiff.mpr тЯиhxB, hxTтЯй
    exact P.eq_of_mem_parts hB hC hxB (Finset.mem_sdiff.mp hxCdiff).1
  rw [parts_singletonResidualRefinement,
    Finset.card_union_of_disjoint hdisjoint,
    Finset.card_image_of_injective T Finset.singleton_injective,
    Finset.card_image_of_injOn hinj]

/-! ## Reserved representatives and every intermediate part count -/

/-- A finite partition admits a set of representatives containing one
vertex from every part and having the same cardinality as the part family. -/
theorem exists_representativeFinset {╬▒ : Type*} [DecidableEq ╬▒]
    {s : Finset ╬▒} (P : Finpartition s) :
    тИГ R : Finset ╬▒, R тКЖ s тИз R.card = P.parts.card тИз
      тИА B тИИ P.parts, тИГ r тИИ R, r тИИ B := by
  obtain тЯиR, hRs, hbijтЯй := P.exists_subset_part_bijOn
  refine тЯиR, hRs, ?_, ?_тЯй
  ┬╖ simpa using hbij.ncard_eq
  ┬╖ intro B hB
    obtain тЯиr, hrR, hrpartтЯй := hbij.surjOn hB
    refine тЯиr, hrR, ?_тЯй
    have hrs : r тИИ s := hRs hrR
    have hmem : r тИИ P.part r := P.mem_part hrs
    simpa [hrpart] using hmem

/-- Every integer between the number of parts of `P` and the cardinality of
the underlying finite set occurs as the exact number of parts of a refinement
of `P`.  This includes the empty-set case. -/
theorem exists_finpartition_refinement_card_eq {╬▒ : Type*}
    [DecidableEq ╬▒] {s : Finset ╬▒} (P : Finpartition s) {k : тДХ}
    (hlo : P.parts.card тЙд k) (hhi : k тЙд s.card) :
    тИГ Q : Finpartition s, Q.parts.card = k тИз Q тЙд P := by
  obtain тЯиR, hRs, hRcard, hRmeetтЯй := exists_representativeFinset P
  have havailable : k - P.parts.card тЙд (s \ R).card := by
    rw [Finset.card_sdiff_of_subset hRs, hRcard]
    exact Nat.sub_le_sub_right hhi P.parts.card
  obtain тЯиT, hTsub, hTcardтЯй :=
    Finset.exists_subset_card_eq
      (s := s \ R) (n := k - P.parts.card) havailable
  have hTs : T тКЖ s := hTsub.trans Finset.sdiff_subset
  have hremain : тИА B тИИ P.parts, (B \ T).Nonempty := by
    intro B hB
    obtain тЯиr, hrR, hrBтЯй := hRmeet B hB
    refine тЯиr, Finset.mem_sdiff.mpr тЯиhrB, ?_тЯйтЯй
    intro hrT
    exact (Finset.mem_sdiff.mp (hTsub hrT)).2 hrR
  let Q := singletonResidualRefinement P hTs hremain
  refine тЯиQ, ?_, singletonResidualRefinement_le P hTs hremainтЯй
  rw [show Q.parts.card = T.card + P.parts.card from
    card_parts_singletonResidualRefinement P hTs hremain,
    hTcard, Nat.sub_add_cancel hlo]

/-! ## Preservation of properness and part-size bounds -/

/-- Refining a proper vertex partition preserves properness because every
new part is contained in an old independent part. -/
theorem mem_partitionColoringEvent_of_refines {n : тДХ}
    {G : LabeledGraph n} {P Q : VertexPartition n}
    (hQP : Q тЙд P) (hP : G тИИ partitionColoringEvent P) :
    G тИИ partitionColoringEvent Q := by
  intro C hC
  obtain тЯиB, hB, hCBтЯй := hQP hC
  exact Set.Pairwise.mono (by simpa using hCB) (hP B hB)

/-- A uniform upper bound on old part sizes is inherited by every part of a
refinement. -/
theorem part_card_bound_of_refines {n b : тДХ}
    {P Q : VertexPartition n} (hQP : Q тЙд P)
    (hP : тИА B тИИ P.parts, B.card тЙд b) :
    тИА C тИИ Q.parts, C.card тЙд b := by
  intro C hC
  obtain тЯиB, hB, hCBтЯй := hQP hC
  exact (Finset.card_le_card hCB).trans (hP B hB)

/-- Public deterministic refinement package for manuscript (4.5).  Starting
from a proper partition with `p` nonempty parts, every `k` with
`p тЙд k тЙд n` is realized by a refining proper partition.  The refinement
witness explicitly preserves a supplied maximum-part-size bound. -/
theorem exists_bounded_proper_refinement_card_eq
    {n p k b : тДХ} (G : LabeledGraph n) (P : VertexPartition n)
    (hproper : G тИИ partitionColoringEvent P)
    (hp : P.parts.card = p) (hpk : p тЙд k) (hkn : k тЙд n)
    (hbound : тИА B тИИ P.parts, B.card тЙд b) :
    тИГ Q : VertexPartition n,
      Q.parts.card = k тИз Q тЙд P тИз
        G тИИ partitionColoringEvent Q тИз
          тИА C тИИ Q.parts, C.card тЙд b := by
  have hlo : P.parts.card тЙд k := hp.trans_le hpk
  have hhi : k тЙд (Finset.univ : Finset (Fin n)).card := by
    simpa using hkn
  obtain тЯиQ, hQcard, hQPтЯй :=
    exists_finpartition_refinement_card_eq P hlo hhi
  exact тЯиQ, hQcard, hQP,
    mem_partitionColoringEvent_of_refines hQP hproper,
    part_card_bound_of_refines hQP hboundтЯй

end Erdos625

end Erdos625SelfContained_Module_Erdos625_FinpartitionRefinement
