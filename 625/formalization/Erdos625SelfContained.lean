BEGIN SOURCE MODULE: Erdos625.Section9CappedFixedFExpansion
Source: Erdos625/Section9CappedFixedFExpansion.lean
Normalized SHA-256: 4c4ac5cfb761c4efccfe4d359ea4ee5afac1319de89e8726fad8790d402b5a41
