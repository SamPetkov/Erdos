private def extendResidualMatching
    {L R : Type*}
    [Fintype L] [Fintype R] [DecidableEq L] [DecidableEq R]
    {S : Finset L} {T : Finset R} (exposed : (тЖСS) тЙГ (тЖСT))
    (residual : {x : L // x тИЙ S} тЙГ {y : R // y тИЙ T}) :
    MatchingExtensions S T exposed := by
