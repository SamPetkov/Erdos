  leftUnique :
    тИА eтВБ тИИ edges, тИА eтВВ тИИ edges, eтВБ.1 = eтВВ.1 -> eтВБ = eтВВ
  rightUnique :
    тИА eтВБ тИИ edges, тИА eтВВ тИИ edges, eтВБ.2 = eтВВ.2 -> eтВБ = eтВВ

