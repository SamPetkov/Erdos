  rw [profileDualMean_eq_sum_weight_size]
  calc
    (тИС i : Fin (alpha + 1),
        profileDualWeight (profileDeficitAffineB alpha - lambda) i *
          profileClassSize i) =
        тИС i : Fin (alpha + 1),
          profileDeficitWeight alpha lambda i *
            ((alpha : тДЭ) - profileDeficit alpha i) := by
      apply Finset.sum_congr rfl
