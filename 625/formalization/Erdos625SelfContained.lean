although applications below only use `0 ≤ x`. -/
theorem abs_neg_log_one_sub_sub_le {x : ℝ} (hx : |x| ≤ 1 / 2) :
    |-Real.log (1 - x) - x| ≤ 2 * x ^ 2 := by
  have hxLower : -(1 / 2 : ℝ) ≤ x := (abs_le.mp hx).1
